  letter-spacing: 0.06em;
  color: var(--fg-2);
}
.macroBar {
  height: 10px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.06);
  position: relative;
  overflow: hidden;
}
.macroBar::after {
  content: "";
  position: absolute;
  inset: 0;
  width: var(--w, 50%);
  background: var(
    --barColor,
    linear-gradient(90deg, var(--accent-cyan), var(--success))
  );

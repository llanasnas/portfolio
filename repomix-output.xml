/* Data packets travelling along a horizontal beam */
.beam {
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(251, 191, 36, 0.5), transparent);
  box-shadow: 0 0 8px rgba(251, 191, 36, 0.5);

/* ============================================================
   ABOUT — cyberpunk operator profile
   ============================================================ */

.root {
  position: relative;
  background: #04050a;
  color: var(--fg-1);
  overflow: hidden;
  isolation: isolate;
  font-family: var(--font-sans);
}

.root::before {
  content: "";
  position: fixed;
  inset: 0;
  background:
    radial-gradient(
      60% 50% at 15% 8%,
      rgba(106, 166, 255, 0.16) 0%,
      transparent 70%
    ),
    radial-gradient(
      50% 50% at 100% 5%,
      rgba(184, 123, 255, 0.14) 0%,
      transparent 70%
    ),
    radial-gradient(
      70% 60% at 50% 100%,
      rgba(90, 215, 255, 0.08) 0%,
      transparent 75%
    );
  pointer-events: none;
  z-index: 0;
}

/* ── Ambient FX ── */
.grid {
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(106, 166, 255, 0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(106, 166, 255, 0.05) 1px, transparent 1px);
  background-size: 56px 56px;
  mask-image: radial-gradient(
    ellipse 80% 70% at 50% 50%,
    #000 30%,
    transparent 80%
  );
  pointer-events: none;
  z-index: 1;
}

.particles {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 1;
  overflow: hidden;
}
.particles span {
  position: absolute;
  display: block;
  border-radius: 50%;
  background: var(--accent-cyan);
  box-shadow:
    0 0 8px var(--accent-cyan),
    0 0 14px rgba(90, 215, 255, 0.6);
  animation: float linear infinite;
  opacity: 0.7;
}
.particles span:nth-child(3n) {
  background: var(--accent-violet);
  box-shadow:
    0 0 10px var(--accent-violet),
    0 0 18px rgba(184, 123, 255, 0.55);
}
@keyframes float {
  0% {
    transform: translate3d(0, 100vh, 0) scale(0.6);
    opacity: 0;
  }
  20% {
    opacity: 0.9;
  }
  100% {
    transform: translate3d(40px, -10vh, 0) scale(1);
    opacity: 0;
  }
}

.beams {
  position: fixed;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}
.beam {
  position: absolute;
  top: -20%;
  width: 2px;
  height: 140%;
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(106, 166, 255, 0.5) 50%,
    transparent 100%
  );
  filter: blur(1px);
  animation: beamSweep 8s ease-in-out infinite;
}
.beam:nth-child(1) {
  left: 14%;
  animation-delay: 0s;
}
.beam:nth-child(2) {
  left: 42%;
  animation-delay: 1.6s;
  background: linear-gradient(
    180deg,
    transparent,
    rgba(184, 123, 255, 0.45),
    transparent
  );
}
.beam:nth-child(3) {
  left: 72%;
  animation-delay: 3.2s;
}
.beam:nth-child(4) {
  left: 90%;
  animation-delay: 4.8s;
  background: linear-gradient(
    180deg,
    transparent,
    rgba(90, 215, 255, 0.45),
    transparent
  );
}
@keyframes beamSweep {
  0%,
  100% {
    opacity: 0;
    transform: translateY(-20px) scaleY(0.6);
  }
  50% {
    opacity: 1;
    transform: translateY(20px) scaleY(1);
  }
}

/* ============================================================
   HERO — TERMINAL BOOT
   ============================================================ */
.hero {
  position: relative;
  min-height: 100vh;
  padding: calc(var(--header-h, 56px) + 3rem) 1.5rem 4rem;
  z-index: 2;
}
.heroInner {
  position: relative;
  max-width: 1400px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: center;
}
@media (min-width: 1024px) {
  .heroInner {
    grid-template-columns: 1.4fr 0.9fr;
    gap: 5rem;
  }
}

/* Terminal */
.terminal {
  position: relative;
  z-index: 3;
  font-family: var(--font-mono);
}
.term__head {
  display: flex;
  align-items: center;
  gap: 0.45rem;
  padding-bottom: 0.7rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  font-size: 10px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--fg-3);
}
.term__head::before {
  content: "";
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--success);
  box-shadow: 0 0 8px var(--success);
  margin-right: 0.6rem;
  animation: pulseDot 1.8s ease-in-out infinite;
}
@keyframes pulseDot {
  0%,
  100% {
    opacity: 0.5;
    transform: scale(0.9);
  }
  50% {
    opacity: 1;
    transform: scale(1.2);
  }
}

.term__prompt {
  margin-top: 1.2rem;
  font-size: 13px;
  color: var(--accent-cyan);
  letter-spacing: 0.04em;
}
.term__prompt span {
  color: var(--fg-2);
  margin-left: 0.5rem;
}
.term__prompt::before {
  content: "$";
  color: var(--accent-violet);
  margin-right: 0.5rem;
  font-weight: 700;
}

/* Name with glitch */
.name {
  font-family: var(--font-sans);
  letter-spacing: -0.04em;

  background: linear-gradient(#fff 0%, #c8cde6 55%, #6aa6ff 100%);

  -webkit-background-clip: text;
  background-clip: text;

  color: transparent;
  -webkit-text-fill-color: transparent;

  filter: drop-shadow(0 0 32px #6aa6ff52) drop-shadow(0 0 80px #b87bff38);

  margin: 1.4rem 0 0;

  font-size: clamp(2.8rem, 8vw, 6.4rem);
  font-weight: 800;
  line-height: 0.95;
  position: relative;
}
.name__row {
  display: block;
}
.name__row span {
  display: inline-block;
  transform: translateY(120%);
  opacity: 0;
}

.name::before,
.name::after {
  content: attr(data-text);
  position: absolute;
  inset: 0;
  background: inherit;
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  pointer-events: none;
  mix-blend-mode: screen;
  opacity: 0.4;
}
.name::before {
  text-shadow: -1px 0 var(--accent-cyan);
  animation: glitchA 4s infinite steps(1);
  clip-path: inset(0 0 50% 0);
}
.name::after {
  text-shadow: 1px 0 var(--accent-violet);
  animation: glitchB 4s infinite steps(1) -2s;
  clip-path: inset(50% 0 0 0);
}
@keyframes glitchA {
  0% {
    transform: translate(0, 0);
    opacity: 0.35;
  }
  8% {
    transform: translate(-3px, 1px);
    opacity: 0.55;
  }
  10% {
    transform: translate(1px, -2px);
    opacity: 0.3;
  }
  12% {
    transform: translate(-1px, 1px);
    opacity: 0.45;
  }
  14% {
    transform: translate(0, 0);
    opacity: 0.35;
  }
  40% {
    transform: translate(0, 0);
    opacity: 0.35;
  }
  41% {
    transform: translate(-2px, 2px);
    opacity: 0.6;
  }
  42% {
    transform: translate(1px, -1px);
    opacity: 0.3;
  }
  43% {
    transform: translate(0, 0);
    opacity: 0.35;
  }
  70% {
    transform: translate(0, 0);
    opacity: 0.35;
  }
  71% {
    transform: translate(-1px, 1px);
    opacity: 0;
  }
  74% {
    transform: translate(0, 0);
    opacity: 0.35;
  }
  100% {
    transform: translate(0, 0);
    opacity: 0.35;
  }
}
@keyframes glitchB {
  0% {
    transform: translate(0, 0);
    opacity: 0.35;
  }
  8% {
    transform: translate(3px, -1px);
    opacity: 0.55;
  }
  10% {
    transform: translate(-2px, 2px);
    opacity: 0.3;
  }
  12% {
    transform: translate(1px, -1px);
    opacity: 0.45;
  }
  14% {
    transform: translate(0, 0);
    opacity: 0.35;
  }
  60% {
    transform: translate(0, 0);
    opacity: 0.35;
  }
  61% {
    transform: translate(2px, 1px);
    opacity: 0.6;
  }
  62% {
    transform: translate(-1px, -2px);
    opacity: 0.3;
  }
  63% {
    transform: translate(0, 0);
    opacity: 0.35;
  }
  85% {
    transform: translate(0, 0);
    opacity: 0.35;
  }
  86% {
    transform: translate(1px, -1px);
    opacity: 0;
  }
  95% {
    transform: translate(0, 0);
    opacity: 0.35;
  }
  100% {
    transform: translate(0, 0);
    opacity: 0.35;
  }
}

.roleRow {
  margin-top: 1.4rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
}
.roleChip {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  padding: 0.45rem 0.85rem;
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--accent-cyan);
  border: 1px solid rgba(90, 215, 255, 0.3);
  border-radius: 999px;
  background: rgba(90, 215, 255, 0.05);
  backdrop-filter: blur(8px);
}
.roleChip.violet {
  color: var(--accent-violet);
  border-color: rgba(184, 123, 255, 0.3);
  background: rgba(184, 123, 255, 0.05);
}
.roleChip svg {
  width: 12px;
  height: 12px;
}

.summary {
  margin: 1.6rem 0 0;
  max-width: 660px;
  font-size: 1rem;
  color: var(--fg-2);
  line-height: 1.7;
}

.heroActions {
  margin-top: 1.8rem;
  display: inline-flex;
  flex-wrap: wrap;
  gap: 0.7rem;
}

/* ID Card */
.idCard {
  position: relative;
  padding: 1.4rem;
  border-radius: 16px;
  border: 1px solid rgba(106, 166, 255, 0.3);
  background:
    linear-gradient(
      160deg,
      rgba(106, 166, 255, 0.06),
      rgba(184, 123, 255, 0.04)
    ),
    rgba(10, 12, 20, 0.7);
  backdrop-filter: blur(14px);
  box-shadow:
    0 30px 80px rgba(0, 0, 0, 0.6),
    0 0 60px rgba(106, 166, 255, 0.18),
    inset 0 1px 0 rgba(255, 255, 255, 0.05);
  overflow: hidden;
}
.idCard__bg {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    45deg,
    rgba(255, 255, 255, 0.015) 0 10px,
    transparent 10px 20px
  );
  pointer-events: none;
}
.idCard__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--fg-3);
  margin-bottom: 1.2rem;
}
.idCard__head strong {
  color: var(--accent-cyan);
  font-weight: 500;
}

.idCard__avatar {
  position: relative;
  display: grid;
  place-items: center;
  width: 120px;
  height: 120px;
  margin: 0 auto 1rem;
}
.idCard__avatar img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.03);
}
.idCard__ring {
  position: absolute;
  inset: -10px;
  border-radius: 50%;
  border: 1.5px dashed rgba(90, 215, 255, 0.5);
  animation: spin 20s linear infinite;
  pointer-events: none;
}
.idCard__ringInner {
  position: absolute;
  inset: -22px;
  border-radius: 50%;
  border: 1px solid rgba(184, 123, 255, 0.35);
  animation: spin 30s linear infinite reverse;
  pointer-events: none;
}
@keyframes spin {
  from {
    transform: rotate(0);
  }
  to {
    transform: rotate(360deg);
  }
}

.idCard__name {
  margin: 0;
  text-align: center;
  font-family: var(--font-mono);
  font-size: 13px;
  letter-spacing: 0.18em;
  color: var(--fg-1);
  text-transform: uppercase;
}
.idCard__sub {
  text-align: center;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.22em;
  color: var(--fg-3);
  margin: 0.3rem 0 1.2rem;
  text-transform: uppercase;
}

.idCard__stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.6rem;
  margin-top: 1rem;
  padding-top: 1rem;
  border-top: 1px dashed rgba(255, 255, 255, 0.08);
}
.idCard__stat {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}
.idCard__stat span {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.24em;
  color: var(--fg-3);
  text-transform: uppercase;
}
.idCard__stat strong {
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--fg-1);
}
.idCard__stat.accent strong {
  color: var(--accent-cyan);
}
.idCard__stat.violet strong {
  color: var(--accent-violet);
}

.idCard__hex {
  position: absolute;
  top: 14px;
  right: 14px;
  color: rgba(90, 215, 255, 0.55);
}

/* HUD corners — reusable */
.hudCorner {
  position: absolute;
  width: 22px;
  height: 22px;
  border: 1.5px solid var(--accent-cyan);
  opacity: 0.7;
  filter: drop-shadow(0 0 6px var(--accent-cyan));
  pointer-events: none;
}
.hudCorner.tl {
  top: 8px;
  left: 8px;
  border-right: 0;
  border-bottom: 0;
}
.hudCorner.tr {
  top: 8px;
  right: 8px;
  border-left: 0;
  border-bottom: 0;
}
.hudCorner.bl {
  bottom: 8px;
  left: 8px;
  border-right: 0;
  border-top: 0;
}
.hudCorner.br {
  bottom: 8px;
  right: 8px;
  border-left: 0;
  border-top: 0;
}

/* ============================================================
   SECTION BASE
   ============================================================ */
.section {
  position: relative;
  z-index: 2;
  padding: 6rem 1.5rem;
}
.sectionInner {
  max-width: 1400px;
  margin: 0 auto;
}
.sectionLabel {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--accent-cyan);
  margin-bottom: 1rem;
  display: inline-block;
  padding: 0.35rem 0.75rem;
  border-left: 2px solid var(--accent-cyan);
}
.sectionLabel.violet {
  color: var(--accent-violet);
  border-color: var(--accent-violet);
}
.sectionLabel.green {
  color: var(--success);
  border-color: var(--success);
}

.h2 {
  font-size: clamp(2rem, 4.4vw, 3.8rem);
  font-weight: 700;
  line-height: 1.05;
  letter-spacing: -0.02em;
  margin: 0 0 1.2rem;
  background: linear-gradient(180deg, #fff, #a8c8ff);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.sectionLead {
  font-size: 1rem;
  color: var(--fg-3);
  max-width: 720px;
  line-height: 1.7;
  margin: 0 0 2.4rem;
}

/* ============================================================
   SKILL MATRIX
   ============================================================ */
.matrix {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.2rem;
}
@media (min-width: 720px) {
  .matrix {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media (min-width: 1100px) {
  .matrix {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* ── Neon RGB cyberpunk border (animated conic) ── */
.skillCard {
  position: relative;
  padding: 2px;
  border-radius: 14px;
  overflow: hidden;
  isolation: isolate;
  background: transparent;
  transition:
    transform 0.35s var(--ease-spring),
    box-shadow 0.4s ease;
  box-shadow:
    0 12px 30px rgba(0, 0, 0, 0.5),
    0 0 28px rgba(255, 43, 214, 0.18),
    0 0 38px rgba(90, 215, 255, 0.14),
    0 0 56px rgba(184, 123, 255, 0.12);
}
/* Rotating rainbow ring */
.skillCard::before {
  content: "";
  position: absolute;
  inset: -50%;
  background: conic-gradient(
    from 0deg,
    #ff2bd6 0%,
    #5ad7ff 18%,
    #6aa6ff 35%,
    #b87bff 52%,
    #4ade80 70%,
    #ff2bd6 100%
  );
  animation: rgbSpin 6s linear infinite;
  z-index: 0;
}
/* Inner dark panel */
.skillCard__panel {
  position: relative;
  z-index: 1;
  padding: 1.4rem 1.4rem 1.5rem;
  border-radius: 12px;
  background: linear-gradient(
    180deg,
    rgba(10, 12, 20, 0.97),
    rgba(4, 5, 10, 0.99)
  );
  backdrop-filter: blur(20px);
  height: 100%;
}
.skillCard:hover {
  transform: translateY(-4px);
  box-shadow:
    0 18px 40px rgba(0, 0, 0, 0.55),
    0 0 42px rgba(255, 43, 214, 0.32),
    0 0 56px rgba(90, 215, 255, 0.25),
    0 0 80px rgba(184, 123, 255, 0.22);
}

@keyframes rgbSpin {
  to {
    transform: rotate(360deg);
  }
}

.skillCard__head {
  display: flex;
  align-items: center;
  gap: 0.7rem;
  margin-bottom: 1rem;
}
.skillCard__icon {
  width: 40px;
  height: 40px;
  display: grid;
  place-items: center;
  border-radius: 10px;
  border: 1px solid rgba(90, 215, 255, 0.3);
  background: linear-gradient(
    135deg,
    rgba(90, 215, 255, 0.1),
    rgba(184, 123, 255, 0.06)
  );
  color: var(--accent-cyan);
}
.skillCard__title {
  margin: 0;
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.22em;
  color: var(--fg-1);
  text-transform: uppercase;
}
.skillCard__count {
  margin-left: auto;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.15em;
  color: var(--fg-3);
}

.skillCard__list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}
.skillCard__list li {
  font-family: var(--font-mono);
  font-size: 11px;
  padding: 0.35rem 0.7rem;
  border-radius: 6px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.025);
  color: var(--fg-2);
  letter-spacing: 0.05em;
}
.skillCard.violet .skillCard__icon {
  color: var(--accent-violet);
  border-color: rgba(184, 123, 255, 0.35);
}
.skillCard.green .skillCard__icon {
  color: var(--success);
  border-color: rgba(74, 222, 128, 0.35);
}
.skillCard.warning .skillCard__icon {
  color: var(--warning);
  border-color: rgba(251, 191, 36, 0.35);
}

/* ============================================================
   CAREER LOG — vertical timeline
   ============================================================ */
.log {
  position: relative;
  margin: 0 auto;
  max-width: 1100px;
}
.log__rail {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 22px;
  width: 1.5px;
  background: linear-gradient(
    180deg,
    var(--accent-cyan),
    var(--accent-violet) 60%,
    transparent
  );
  transform-origin: top;
  transform: scaleY(0);
  box-shadow: 0 0 12px rgba(90, 215, 255, 0.45);
}
@media (min-width: 720px) {
  .log__rail {
    left: 36px;
  }
}

.logItem {
  position: relative;
  padding-left: 60px;
  padding-bottom: 3rem;
}
@media (min-width: 720px) {
  .logItem {
    padding-left: 96px;
  }
}

.logItem__node {
  position: absolute;
  top: 0.3rem;
  left: 12px;
  width: 22px;
  height: 22px;
  display: grid;
  place-items: center;
}
@media (min-width: 720px) {
  .logItem__node {
    left: 26px;
  }
}

.logItem__node::before {
  content: "";
  position: absolute;
  inset: 4px;
  border-radius: 50%;
  background: var(--accent-cyan);
  box-shadow: 0 0 10px var(--accent-cyan);
}
.logItem__node::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 1px solid rgba(90, 215, 255, 0.5);
  animation: pulseRing 2.2s ease-out infinite;
}
.logItem.current .logItem__node::before {
  background: var(--success);
  box-shadow: 0 0 12px var(--success);
}
.logItem.current .logItem__node::after {
  border-color: rgba(74, 222, 128, 0.55);
}
@keyframes pulseRing {
  0% {
    transform: scale(0.6);
    opacity: 1;
  }
  100% {
    transform: scale(1.8);
    opacity: 0;
  }
}

.logItem__meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.7rem;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--fg-3);
  margin-bottom: 0.4rem;
}
.logItem__meta span.live {
  color: var(--success);
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
}
.logItem__meta span.live::before {
  content: "";
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--success);
  box-shadow: 0 0 8px var(--success);
  animation: pulseDot 1.6s ease-in-out infinite;
}
.logItem__title {
  margin: 0 0 0.2rem;
  font-size: clamp(1.1rem, 2vw, 1.4rem);
  font-weight: 600;
  color: var(--fg-1);
}
.logItem__company {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.12em;
  color: var(--accent-cyan);
  text-transform: uppercase;
  margin-bottom: 0.8rem;
}
.logItem__bullets {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  gap: 0.5rem;
}
.logItem__bullets li {
  position: relative;
  padding-left: 1.1rem;
  font-size: 0.92rem;
  color: var(--fg-2);
  line-height: 1.6;
}
.logItem__bullets li::before {
  content: "›";
  position: absolute;
  left: 0;
  color: var(--accent-cyan);
}

/* ============================================================
   ACHIEVEMENTS / EDUCATION
   ============================================================ */
.achievements {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}
@media (min-width: 720px) {
  .achievements {
    grid-template-columns: repeat(3, 1fr);
  }
}

.achv {
  position: relative;
  padding: 1.5rem;
  border-radius: 14px;
  border: 1px solid rgba(184, 123, 255, 0.25);
  background:
    linear-gradient(
      140deg,
      rgba(184, 123, 255, 0.06),
      rgba(106, 166, 255, 0.04)
    ),
    rgba(10, 12, 20, 0.55);
  backdrop-filter: blur(10px);
  overflow: hidden;
}
.achv__rarity {
  position: absolute;
  top: 12px;
  right: 12px;
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  padding: 0.25rem 0.55rem;
  border-radius: 999px;
  border: 1px solid rgba(184, 123, 255, 0.4);
  color: var(--accent-violet);
  background: rgba(184, 123, 255, 0.08);
}
.achv.rare .achv__rarity {
  color: var(--accent-cyan);
  border-color: rgba(90, 215, 255, 0.4);
  background: rgba(90, 215, 255, 0.08);
}
.achv.epic .achv__rarity {
  color: var(--accent-violet);
  border-color: rgba(184, 123, 255, 0.4);
}
.achv.legendary .achv__rarity {
  color: var(--warning);
  border-color: rgba(251, 191, 36, 0.4);
  background: rgba(251, 191, 36, 0.08);
}

.achv__icon {
  width: 44px;
  height: 44px;
  display: grid;
  place-items: center;
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: var(--accent-violet);
  margin-bottom: 1rem;
}
.achv.rare .achv__icon {
  color: var(--accent-cyan);
}
.achv.legendary .achv__icon {
  color: var(--warning);
}

.achv__title {
  margin: 0 0 0.4rem;
  font-size: 1rem;
  color: var(--fg-1);
  font-weight: 600;
  line-height: 1.3;
}
.achv__org {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.12em;
  color: var(--accent-cyan);
  margin: 0;
}
.achv__year {
  margin-top: 0.6rem;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.2em;
  color: var(--fg-3);
}

/* ============================================================
   LANGUAGES — HUD bars
   ============================================================ */
.langs {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
  max-width: 720px;
}
.lang {
  position: relative;
  padding: 1.1rem 1.3rem;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.025);
  backdrop-filter: blur(10px);
}
.lang__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--fg-1);
  margin-bottom: 0.6rem;
}
.lang__head em {
  font-style: normal;
  font-size: 10px;
  color: var(--fg-3);
  letter-spacing: 0.18em;
}
.lang__bar {
  height: 8px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.05);
  overflow: hidden;
  position: relative;
}
.lang__bar::after {
  content: "";
  position: absolute;
  inset: 0;
  width: var(--w, 50%);
  background: linear-gradient(90deg, var(--accent-cyan), var(--accent-violet));
  box-shadow: 0 0 14px rgba(90, 215, 255, 0.5);
  border-radius: inherit;
}

/* ============================================================
   FEATURED PROJECTS
   ============================================================ */
.featGrid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.4rem;
}
@media (min-width: 900px) {
  .featGrid {
    grid-template-columns: 1fr 1fr;
  }
}

.feat {
  position: relative;
  display: block;
  padding: 1.6rem;
  border-radius: 16px;
  border: 1px solid rgba(106, 166, 255, 0.25);
  background:
    linear-gradient(
      140deg,
      rgba(106, 166, 255, 0.06),
      rgba(184, 123, 255, 0.04)
    ),
    rgba(10, 12, 20, 0.6);
  backdrop-filter: blur(14px);
  text-decoration: none;
  color: inherit;
  overflow: hidden;
  transition:
    transform 0.35s var(--ease-spring),
    border-color 0.3s ease,
    box-shadow 0.3s ease;
}
.feat::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(
    120% 100% at 0% 0%,
    rgba(90, 215, 255, 0.18),
    transparent 60%
  );
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
}
.feat:hover {
  transform: translateY(-3px);
  border-color: rgba(90, 215, 255, 0.55);
  box-shadow:
    0 24px 60px rgba(0, 0, 0, 0.55),
    0 0 40px rgba(90, 215, 255, 0.22);
}
.feat:hover::before {
  opacity: 1;
}
.feat__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--fg-3);
  margin-bottom: 1rem;
}
.feat__head strong {
  color: var(--accent-cyan);
}
.feat.violet .feat__head strong {
  color: var(--accent-violet);
}
.feat__title {
  margin: 0 0 0.4rem;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--fg-1);
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
}
.feat__title svg {
  color: var(--accent-cyan);
}
.feat.violet .feat__title svg {
  color: var(--accent-violet);
}
.feat__desc {
  margin: 0 0 1rem;
  color: var(--fg-2);
  font-size: 0.93rem;
  line-height: 1.6;
}
.feat__tech {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}
.feat__tech span {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.12em;
  padding: 0.3rem 0.65rem;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: var(--fg-2);
  background: rgba(255, 255, 255, 0.02);
}
.feat__arrow {
  position: absolute;
  bottom: 1.4rem;
  right: 1.4rem;
  color: var(--accent-cyan);
  transition: transform 0.3s var(--ease-spring);
}
.feat.violet .feat__arrow {
  color: var(--accent-violet);
}
.feat:hover .feat__arrow {
  transform: translateX(4px);
}

/* ============================================================
   CONTACT CTA
   ============================================================ */
.cta {
  position: relative;
  padding: 5rem 1.5rem 6rem;
  text-align: center;
}
.ctaCard {
  position: relative;
  max-width: 760px;
  margin: 0 auto;
  padding: 3rem 2rem;
  border-radius: 22px;
  border: 1px solid rgba(106, 166, 255, 0.35);
  background:
    linear-gradient(
      160deg,
      rgba(106, 166, 255, 0.08),
      rgba(184, 123, 255, 0.05)
    ),
    rgba(10, 12, 20, 0.6);
  backdrop-filter: blur(14px);
  box-shadow:
    0 40px 100px rgba(0, 0, 0, 0.6),
    0 0 80px rgba(106, 166, 255, 0.2);
  overflow: hidden;
}
.ctaCmd {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.2em;
  color: var(--accent-cyan);
  margin-bottom: 1.4rem;
  text-transform: uppercase;
}
.ctaCmd::before {
  content: "$";
  color: var(--accent-violet);
  margin-right: 0.6rem;
  font-weight: 700;
}
.ctaTitle {
  margin: 0 0 1rem;
  font-size: clamp(2rem, 5vw, 3.6rem);
  font-weight: 800;
  line-height: 1;
  letter-spacing: -0.03em;
  background: linear-gradient(180deg, #fff 0%, #c8cde6 50%, #b87bff 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
.ctaSub {
  margin: 0 auto 2rem;
  max-width: 540px;
  color: var(--fg-2);
  font-size: 0.98rem;
  line-height: 1.6;
}
.ctaButtons {
  display: inline-flex;
  flex-wrap: wrap;
  gap: 0.85rem;
  justify-content: center;
}

/* ============================================================
   BUTTONS — primary + ghost (reusable)
   ============================================================ */
.btnPrimary {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.95rem 1.6rem;
  font-family: var(--font-mono);
  font-size: 0.78rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #fff;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: linear-gradient(
    135deg,
    rgba(184, 123, 255, 0.95),
    rgba(106, 166, 255, 0.95)
  );
  box-shadow:
    0 18px 40px rgba(184, 123, 255, 0.4),
    0 0 60px rgba(106, 166, 255, 0.28),
    inset 0 1px 0 rgba(255, 255, 255, 0.2);
  text-decoration: none;
  overflow: hidden;
  isolation: isolate;
  transition:
    transform 0.3s var(--ease-spring),
    box-shadow 0.3s ease;
}
.btnPrimary::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    120deg,
    transparent 0%,
    rgba(255, 255, 255, 0.18) 50%,
    transparent 100%
  );
  transform: translateX(-100%);
  transition: transform 0.7s ease;
  z-index: -1;
}
.btnPrimary:hover {
  transform: translateY(-2px) scale(1.02);
}
.btnPrimary:hover::before {
  transform: translateX(100%);
}
.btnPrimary svg {
  width: 16px;
  height: 16px;
}

.btnGhost {
  display: inline-flex;
  align-items: center;
  gap: 0.65rem;
  padding: 0.85rem 1.4rem;
  font-family: var(--font-mono);
  font-size: 0.76rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--fg-1);
  border-radius: 999px;
  border: 1px solid rgba(90, 215, 255, 0.3);
  background: linear-gradient(
    135deg,
    rgba(90, 215, 255, 0.05),
    rgba(184, 123, 255, 0.04)
  );
  backdrop-filter: blur(12px);
  text-decoration: none;
  transition:
    border-color 0.3s ease,
    transform 0.3s var(--ease-spring),
    box-shadow 0.3s ease;
}
.btnGhost:hover {
  transform: translateY(-2px);
  border-color: rgba(90, 215, 255, 0.6);
  box-shadow:
    0 14px 30px rgba(0, 0, 0, 0.4),
    0 0 30px rgba(90, 215, 255, 0.22);
}
.btnGhost svg {
  color: var(--accent-cyan);
  width: 16px;
  height: 16px;
}

.btnCV {
  display: inline-flex;
  align-items: center;
  gap: 0.65rem;
  padding: 0.85rem 1.4rem;
  font-family: var(--font-mono);

<file path="components/projects/mincely/MincelyStory.module.css">
/* ============================================================
   MINCELY STORY — cinematic AI recipe page (cyberpunk)
   ============================================================ */

.root {
  position: relative;
  background: #04050a;
  color: var(--fg-1);
  overflow: hidden;
  isolation: isolate;
}

.root::before {
  content: "";
  position: fixed;
  inset: 0;
  background:
    radial-gradient(
      60% 50% at 15% 8%,
      rgba(90, 215, 255, 0.16) 0%,
      transparent 70%
    ),
    radial-gradient(
      50% 50% at 100% 5%,
      rgba(74, 222, 128, 0.1) 0%,
      transparent 70%
    ),
    radial-gradient(
      70% 60% at 50% 100%,
      rgba(184, 123, 255, 0.1) 0%,
      transparent 75%
    );
  pointer-events: none;
  z-index: 0;
}

/* ── Ambient FX ── */
.grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(90, 215, 255, 0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(90, 215, 255, 0.06) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(
    ellipse 80% 70% at 50% 50%,
    #000 30%,
    transparent 80%
  );
  pointer-events: none;
  z-index: 1;
}

.particles {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 1;
  overflow: hidden;
}
.particles span {
  position: absolute;
  display: block;
  width: 2px;
  height: 2px;
  border-radius: 50%;
  background: var(--accent-cyan);
  box-shadow:
    0 0 8px var(--accent-cyan),
    0 0 14px rgba(90, 215, 255, 0.6);
  animation: float linear infinite;
  opacity: 0.7;
}
.particles span:nth-child(3n) {
  background: var(--success);
  box-shadow:
    0 0 10px var(--success),
    0 0 18px rgba(74, 222, 128, 0.55);
}
.particles span:nth-child(5n) {
  background: var(--accent-violet);
  box-shadow:
    0 0 10px var(--accent-violet),
    0 0 18px rgba(184, 123, 255, 0.55);
}
@keyframes float {
  0% {
    transform: translate3d(0, 100vh, 0) scale(0.6);
    opacity: 0;
  }
  20% {
    opacity: 0.9;
  }
  100% {
    transform: translate3d(40px, -10vh, 0) scale(1);
    opacity: 0;
  }
}

.beams {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}
.beam {
  position: absolute;
  top: -20%;
  width: 2px;
  height: 140%;
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(90, 215, 255, 0.5) 50%,
    transparent 100%
  );
  filter: blur(1px);
  animation: beamSweep 8s ease-in-out infinite;
}
.beam:nth-child(1) {
  left: 12%;
  animation-delay: 0s;
}
.beam:nth-child(2) {
  left: 40%;
  animation-delay: 1.6s;
  background: linear-gradient(
    180deg,
    transparent,
    rgba(74, 222, 128, 0.45),
    transparent
  );
}
.beam:nth-child(3) {
  left: 68%;
  animation-delay: 3.2s;
}
.beam:nth-child(4) {
  left: 88%;
  animation-delay: 4.8s;
  background: linear-gradient(
    180deg,
    transparent,
    rgba(184, 123, 255, 0.45),
    transparent
  );
}
@keyframes beamSweep {
  0%,
  100% {
    opacity: 0;
    transform: translateY(-20px) scaleY(0.6);
  }
  50% {
    opacity: 1;
    transform: translateY(20px) scaleY(1);
  }
}

/* ============================================================
   HERO
   ============================================================ */
.hero {
  position: relative;
  min-height: 100vh;
  display: grid;
  justify-items: center;
  align-content: start;
  padding: calc(var(--header-h, 56px) + 3rem) 1.5rem 4rem;
  text-align: center;
}
.heroInner {
  position: relative;
  z-index: 3;
  max-width: 1200px;
  width: 100%;
}

.kicker {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: var(--warning);
  padding: 0.5rem 1rem;
  border: 1px solid rgba(251, 191, 36, 0.35);
  border-radius: 999px;
  background: rgba(251, 191, 36, 0.06);
  backdrop-filter: blur(10px);
  margin-bottom: 1.2rem;
}
.kicker::before {
  content: "";
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--warning);
  box-shadow: 0 0 10px var(--warning);
  animation: pulseDot 1.8s ease-in-out infinite;
}
@keyframes pulseDot {
  0%,
  100% {
    opacity: 0.5;
    transform: scale(0.9);
  }
  50% {
    opacity: 1;
    transform: scale(1.2);
  }
}

/* Cyberpunk chef-hat SVG */
.brandIcon {
  width: 92px;
  height: 92px;
  margin: 0 auto 1.2rem;
  filter: drop-shadow(0 0 16px rgba(90, 215, 255, 0.45))
    drop-shadow(0 0 40px rgba(74, 222, 128, 0.3));
}

.title {
  font-family: var(--font-sans);
  font-size: clamp(4rem, 14vw, 13rem);
  font-weight: 800;
  letter-spacing: -0.04em;
  position: absolute;
  line-height: 0.92;
  margin: 0;
  display: none;
  background: linear-gradient(180deg, #fff 0%, #c8e6da 45%, #5ad7ff 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  filter: drop-shadow(0 0 40px rgba(90, 215, 255, 0.32))
    drop-shadow(0 0 80px rgba(74, 222, 128, 0.18));
}
.title span {
  display: inline-block;
  transform: translateY(120%);
  opacity: 0;
}

.subtitle {
  margin: 1.6rem auto 0;
  max-width: 740px;
  font-size: clamp(1.05rem, 2vw, 1.4rem);
  color: var(--fg-2);
  font-weight: 300;
  letter-spacing: 0.01em;
}
.desc {
  margin: 1.1rem auto 0;
  max-width: 660px;
  font-size: 0.95rem;
  color: var(--fg-3);
  line-height: 1.7;
}

.heroButtons {
  margin-top: 2rem;
  display: inline-flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.9rem;
}

.heroPreview {
  position: relative;
  margin: 3rem auto 0;
  max-width: 1100px;
  perspective: 1800px;
  z-index: 3;
}
.heroPreviewInner {
  position: relative;
  border-radius: 18px;
  overflow: hidden;
  transform-style: preserve-3d;
  border: 1px solid rgba(90, 215, 255, 0.35);
  box-shadow:
    0 30px 80px rgba(0, 0, 0, 0.7),
    0 0 80px rgba(90, 215, 255, 0.28),
    0 0 160px rgba(74, 222, 128, 0.15);
  will-change: transform;
  background: #0a0c14;
}
.heroPreviewInner img {
  display: block;
  width: 100%;
  height: auto;
}

/* HUD corners */
.hudCorner {
  position: absolute;
  width: 26px;
  height: 26px;
  border: 1.5px solid var(--accent-cyan);
  opacity: 0.75;
  filter: drop-shadow(0 0 8px var(--accent-cyan));
}
.hudCorner.tl {
  top: 10px;
  left: 10px;
  border-right: 0;
  border-bottom: 0;
}
.hudCorner.tr {
  top: 10px;
  right: 10px;
  border-left: 0;
  border-bottom: 0;
}
.hudCorner.bl {
  bottom: 10px;
  left: 10px;
  border-right: 0;
  border-top: 0;
}
.hudCorner.br {
  bottom: 10px;
  right: 10px;
  border-left: 0;
  border-top: 0;
}

/* Scroll hint */
.scrollHint {
  position: absolute;
  left: 50%;
  bottom: 1.6rem;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.6rem;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.3em;
  color: var(--fg-3);
  z-index: 4;
}
.scrollHint::after {
  content: "";
  width: 1px;
  height: 38px;
  background: linear-gradient(180deg, var(--accent-cyan), transparent);
  animation: scrollLine 2s ease-in-out infinite;
}
@keyframes scrollLine {
  0%,
  100% {
    transform: scaleY(0.4);
    transform-origin: top;
    opacity: 0.4;
  }
  50% {
    transform: scaleY(1);
    opacity: 1;
  }
}

/* ============================================================
   SECTION LABELS / HEADINGS
   ============================================================ */
.sectionLabel {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--accent-cyan);
  margin-bottom: 1rem;
  display: inline-block;
  padding: 0.35rem 0.75rem;
  border-left: 2px solid var(--accent-cyan);
}
.sectionLabel.violet {
  color: var(--accent-violet);
  border-color: var(--accent-violet);
}
.sectionLabel.green {
  color: var(--success);
  border-color: var(--success);
}

.h2 {
  font-size: clamp(2.2rem, 4.6vw, 4.4rem);
  font-weight: 700;
  line-height: 1.02;
  letter-spacing: -0.025em;
  margin: 0 0 1.4rem;
  background: linear-gradient(180deg, #fff, #a8c8ff);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
.lead {
  font-size: 1.05rem;
  color: var(--fg-2);
  line-height: 1.7;
  max-width: 560px;
}

.featureList {
  list-style: none;
  padding: 0;
  margin: 1.5rem 0 0;
  display: grid;
  gap: 0.7rem;
}
.featureList li {
  display: flex;
  align-items: flex-start;
  gap: 0.7rem;
  font-size: 0.95rem;
  color: var(--fg-2);
}
.featureList li::before {
  content: "";
  flex-shrink: 0;
  width: 14px;
  height: 14px;
  margin-top: 4px;
  border: 1.5px solid var(--accent-cyan);
  background: rgba(90, 215, 255, 0.1);
  box-shadow: 0 0 10px rgba(90, 215, 255, 0.45);
  transform: rotate(45deg);
}

/* ============================================================
   AI ENGINE SCENE — video pinned
   ============================================================ */
.engineWrap {
  position: relative;
  height: 300vh;
}
.enginePin {
  position: sticky;
  top: 0;
  height: 100vh;
  display: grid;
  align-items: center;
  overflow: hidden;
}
.engineLayout {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
  width: 100%;
  max-width: 1500px;
  margin: 0 auto;
  padding: 0 2rem;
  align-items: center;
}
@media (min-width: 1024px) {
  .engineLayout {
    grid-template-columns: 1fr 1.4fr;
  }
}

.videoFrame {
  position: relative;
  border-radius: 14px;
  overflow: hidden;
  border: 1px solid rgba(90, 215, 255, 0.3);
  box-shadow:
    0 40px 100px rgba(0, 0, 0, 0.7),
    0 0 60px rgba(90, 215, 255, 0.25);
  will-change: transform;
  background: #000;
}
.videoFrame video {
  display: block;
  width: 100%;
  height: auto;
  max-height: 85vh;
  object-fit: cover;
}
.scanline {
  position: absolute;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(
    90deg,
    transparent,
    var(--accent-cyan),
    transparent
  );
  filter: blur(1px);
  box-shadow:
    0 0 12px var(--accent-cyan),
    0 0 28px rgba(90, 215, 255, 0.6);
  animation: scanY 3.4s ease-in-out infinite;
  pointer-events: none;
}
@keyframes scanY {
  0% {
    top: 0;
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    top: 100%;
    opacity: 0;
  }
}
.frameEdge {
  position: absolute;
  inset: 0;
  pointer-events: none;
  border-radius: inherit;
  box-shadow:
    inset 0 0 0 1px rgba(90, 215, 255, 0.18),
    inset 0 0 40px rgba(90, 215, 255, 0.08),
    inset 0 0 80px rgba(74, 222, 128, 0.06);
}

/* Fullscreen button */
.fsBtn {
  position: absolute;
  bottom: 14px;
  right: 14px;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  padding: 0;
  border: 1px solid rgba(90, 215, 255, 0.35);
  border-radius: 6px;
  background: rgba(4, 5, 10, 0.6);
  backdrop-filter: blur(8px);
  color: rgba(90, 215, 255, 0.75);
  cursor: pointer;
  opacity: 0;
  transition:
    opacity 0.2s ease,
    color 0.2s ease,
    border-color 0.2s ease,
    box-shadow 0.2s ease;
}
.videoFrame:hover .fsBtn {
  opacity: 1;
}
.fsBtn:hover {
  color: #5ad7ff;
  border-color: rgba(90, 215, 255, 0.7);
  box-shadow:
    0 0 12px rgba(90, 215, 255, 0.4),
    0 0 24px rgba(90, 215, 255, 0.15);
}
.fsBtn:focus-visible {
  outline: none;
  opacity: 1;
  box-shadow: 0 0 0 2px rgba(90, 215, 255, 0.5);
}

/* Fullscreen state — center video, contain */
.videoFrame:fullscreen {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #000;
}
.videoFrame:fullscreen video {
  width: auto;
  height: 100%;
  max-height: 100%;
  max-width: 100%;
  object-fit: contain;
}
.videoFrame:-webkit-full-screen {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #000;
}
.videoFrame:-webkit-full-screen video {
  width: auto;
  height: 100%;
  max-height: 100%;
  max-width: 100%;
  object-fit: contain;
}

/* Provider chips */
.providers {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 0.7rem;
  margin-top: 1.6rem;
}
@media (max-width: 640px) {
  .providers {
    grid-template-columns: 1fr;
  }
}
.provider {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.45rem;
  padding: 0.95rem 1rem;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.025);
  backdrop-filter: blur(10px);
  position: relative;
  overflow: hidden;
}
.provider svg {
  color: var(--accent-cyan);
}
.provider strong {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.2em;
  color: var(--fg-1);
  text-transform: uppercase;
}
.provider span {
  font-size: 0.78rem;
  color: var(--fg-3);
}
.provider.violet {
  border-color: rgba(184, 123, 255, 0.3);
}
.provider.violet svg {
  color: var(--accent-violet);
}
.provider.green {
  border-color: rgba(74, 222, 128, 0.3);
}
.provider.green svg {
  color: var(--success);
}

/* Warning card */
.warnCard {
  margin-top: 1.6rem;
  padding: 1.1rem 1.3rem;
  border: 1px solid rgba(251, 191, 36, 0.3);
  background: rgba(251, 191, 36, 0.05);
  border-radius: 12px;
  font-size: 0.86rem;
  color: var(--fg-2);
  line-height: 1.6;
}
.warnCard strong {
  color: var(--warning);
  font-family: var(--font-mono);
  letter-spacing: 0.18em;
  font-size: 10px;
  display: block;
  margin-bottom: 0.4rem;
}

/* ============================================================
   FORMATS — multi-format import chips
   ============================================================ */
.formats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.85rem;
  margin-top: 1.6rem;
}
@media (min-width: 640px) {
  .formats {
    grid-template-columns: repeat(4, 1fr);
  }
}
.format {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.5rem;
  padding: 1rem 0.95rem;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: linear-gradient(
    135deg,
    rgba(90, 215, 255, 0.05),
    rgba(74, 222, 128, 0.03)
  );
  overflow: hidden;
  isolation: isolate;
}
.format::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(
    120% 100% at 0% 0%,
    rgba(90, 215, 255, 0.12),
    transparent 60%
  );
  z-index: -1;
}
.format svg {
  color: var(--accent-cyan);
}
.format strong {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.18em;
  color: var(--fg-1);
  text-transform: uppercase;
}
.format span {
  font-size: 0.78rem;
  color: var(--fg-3);
}

/* ============================================================
   PINNED SPLIT — for scenes that mirror engine scrub pattern
   ============================================================ */
.splitWrap {
  position: relative;
  height: 300vh;
}
.splitPin {
  position: sticky;
  top: 0;
  height: 100vh;
  display: grid;
  grid-template-columns: 1fr;
  align-items: center;
  overflow: hidden;
}

/* ============================================================
   SPLIT scenes (shared)
   ============================================================ */
.split {
  position: relative;
  min-height: 110vh;
  display: flex;
  align-items: center;
  padding: 8rem 2rem;
}
.splitInner {
  width: 100%;
  max-width: 1500px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: center;
}
@media (min-width: 1024px) {
  .splitInner {
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
  }
  .splitInner.reverse {
    direction: rtl;
  }
  .splitInner.reverse > * {
    direction: ltr;
  }
  .splitInner.wideImg {
    grid-template-columns: 0.85fr 1.55fr;
  }
  .splitInner.narrowImg {
    grid-template-columns: 1.25fr 0.85fr;
  }
  .splitInner.narrowImg .shotFrame {
    max-width: 560px;
    margin-left: auto;
  }
}

.shotFrame {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow:
    0 30px 80px rgba(0, 0, 0, 0.7),
    0 0 60px var(--shotGlow, rgba(90, 215, 255, 0.22));
  will-change: transform;
  background: #000;
}
.shotFrame img {
  display: block;
  width: 100%;
  height: auto;
}
.shotGlow {
  position: absolute;
  inset: -20%;
  background: radial-gradient(
    circle,
    var(--shotGlow, rgba(90, 215, 255, 0.35)) 0%,
    transparent 60%
  );
  pointer-events: none;
  z-index: -1;
  filter: blur(40px);
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin: 1.4rem 0 0.5rem;
}
.tag {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  padding: 0.4rem 0.75rem;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.03);
  color: var(--fg-2);
}

.copy {
  position: relative;
  z-index: 2;
}
.copy p {
  margin: 0;
  color: var(--fg-2);
  line-height: 1.7;
  font-size: 1rem;
}
.copy p + p {
  margin-top: 1rem;
}

.callout {
  margin-top: 1.4rem;
  padding: 1.1rem 1.3rem;
  border-left: 2px solid var(--accent-cyan);
  background: linear-gradient(90deg, rgba(90, 215, 255, 0.08), transparent);
  font-size: 0.88rem;
  color: var(--fg-2);
  border-radius: 0 8px 8px 0;
}
.callout.violet {
  border-left-color: var(--accent-violet);
  background: linear-gradient(90deg, rgba(184, 123, 255, 0.08), transparent);
}
.callout.green {
  border-left-color: var(--success);
  background: linear-gradient(90deg, rgba(74, 222, 128, 0.08), transparent);
}
.callout strong {
  display: block;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--accent-cyan);
  margin-bottom: 0.35rem;
}
.callout.violet strong {
  color: var(--accent-violet);
}
.callout.green strong {
  color: var(--success);
}

/* ============================================================
   TRIPTYCH — three recipe-detail panels, scroll-stack
   ============================================================ */
.triptychWrap {
  position: relative;
  height: 380vh;
}
.triptychPin {
  position: sticky;
  top: 0;
  height: 100vh;
  overflow: hidden;
  display: grid;
  grid-template-columns: 1fr;
  align-items: center;
}
.triptychStage {
  position: relative;
  width: 100%;
  max-width: 1600px;
  margin: 0 auto;
  padding: 0 2rem;
  display: grid;
  grid-template-columns: 1fr;
  gap: 2.5rem;
  align-items: center;
}
@media (min-width: 1024px) {
  .triptychStage {
    grid-template-columns: 0.8fr 1.4fr;
  }
}

.triptychCopy {
  position: relative;
  z-index: 5;
}

.triptychPanels {
  position: relative;
  width: 100%;
  height: 78vh;
  perspective: 2400px;
}
.recipePanel {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100%;
  max-width: 640px;
  height: auto;
  border-radius: 18px;
  overflow: hidden;
  border: 1px solid rgba(90, 215, 255, 0.3);
  background: #0a0c14;
  box-shadow:
    0 40px 100px rgba(0, 0, 0, 0.7),
    0 0 60px rgba(90, 215, 255, 0.18);
  transform-style: preserve-3d;
  will-change: transform, opacity;
}
.recipePanel img {
  display: block;
  width: 100%;
  height: auto;
}
.recipePanel .frameEdge {
  border-radius: inherit;
}
.panelTag {
  position: absolute;
  top: 14px;
  left: 14px;
  padding: 0.35rem 0.7rem;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  border-radius: 999px;
  background: rgba(4, 5, 10, 0.7);
  border: 1px solid rgba(90, 215, 255, 0.5);
  color: var(--accent-cyan);
  z-index: 6;
  backdrop-filter: blur(8px);
}

.triptychProgress {
  position: absolute;
  bottom: 1.4rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 0.5rem;
  z-index: 7;
}
.triptychProgress span {
  width: 36px;
  height: 3px;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 2px;
  overflow: hidden;
  position: relative;
}
.triptychProgress span::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, var(--accent-cyan), var(--success));
  transform-origin: left;
  transform: scaleX(0);
  transition: transform 0.3s ease;
}
.triptychProgress span.active::after {
  transform: scaleX(1);
}

/* ============================================================
   MACROS — cyberpunk bars
   ============================================================ */
.macrosScene {
  position: relative;
  padding: 8rem 2rem;
  min-height: 100vh;
  display: flex;
  align-items: center;
}
.macrosInner {
  width: 100%;
  max-width: 1500px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: center;
}
@media (min-width: 1024px) {
  .macrosInner {
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
  }
}

.macroPanel {
  position: relative;
  padding: 2rem;
  border-radius: 18px;
  border: 1px solid rgba(74, 222, 128, 0.25);
  background:
    linear-gradient(135deg, rgba(74, 222, 128, 0.04), rgba(90, 215, 255, 0.05)),
    rgba(10, 12, 20, 0.6);
  backdrop-filter: blur(14px);
  box-shadow:
    0 30px 80px rgba(0, 0, 0, 0.55),
    0 0 60px rgba(74, 222, 128, 0.15);

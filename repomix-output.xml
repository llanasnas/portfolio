  text-transform: uppercase;
  color: var(--accent-cyan);
}
.finalCard p {
  margin: 0;
  color: var(--fg-2);
  font-size: 0.88rem;
  line-height: 1.6;
}

/* ============================================================
   CTA buttons
   ============================================================ */
.ctaRow {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: stretch;
  gap: 1rem;
}

.cta {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 0.8rem;
  padding: 1rem 1.6rem;
  font-family: var(--font-mono);
  font-size: 0.82rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #fff;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: linear-gradient(
    135deg,
    rgba(90, 215, 255, 0.95),
    rgba(74, 222, 128, 0.9)
  );
  box-shadow:
    0 18px 40px rgba(90, 215, 255, 0.4),
    0 0 60px rgba(74, 222, 128, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.2);
  transition:
    transform 0.3s var(--ease-spring),
    box-shadow 0.3s ease;
  text-decoration: none;
  overflow: hidden;
  isolation: isolate;
}
.cta::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    120deg,
    transparent 0%,
    rgba(255, 255, 255, 0.18) 50%,
    transparent 100%
  );
  transform: translateX(-100%);
  transition: transform 0.7s ease;
  z-index: -1;
}
.cta:hover {
  transform: translateY(-2px) scale(1.02);
  box-shadow:
    0 24px 60px rgba(90, 215, 255, 0.55),
    0 0 80px rgba(74, 222, 128, 0.45),
    inset 0 1px 0 rgba(255, 255, 255, 0.25);
}
.cta:hover::before {
  transform: translateX(100%);
}
.cta:hover .ctaArrow {
  transform: translateX(4px);
}
.ctaArrow {
  transition: transform 0.3s var(--ease-spring);
}

/* Secondary — ghost / outline */
.ctaGhost {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 0.85rem;
  padding: 0.95rem 1.4rem;
  border-radius: 999px;
  border: 1px solid rgba(90, 215, 255, 0.35);
  background: linear-gradient(
    135deg,
    rgba(90, 215, 255, 0.05),
    rgba(74, 222, 128, 0.04)
  );
  backdrop-filter: blur(14px);
  color: var(--fg-1);
  text-decoration: none;
  font-family: var(--font-mono);
  font-size: 0.78rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  transition:
    transform 0.3s var(--ease-spring),
    border-color 0.3s ease,
    box-shadow 0.3s ease,
    background 0.3s ease;
}
.ctaGhost:hover {
  transform: translateY(-2px);
  border-color: rgba(90, 215, 255, 0.7);
  box-shadow:
    0 18px 40px rgba(90, 215, 255, 0.22),
    0 0 40px rgba(90, 215, 255, 0.18);
}
.ctaGhost svg {
  color: var(--accent-cyan);
}

@media (max-width: 560px) {
  .ctaRow {
    flex-direction: column;
    align-items: stretch;
    gap: 0.85rem;
  }
  .cta,
  .ctaGhost {
    justify-content: center;
  }
}

/* ============================================================
   PROGRESS RAIL
   ============================================================ */
.rail {
  position: fixed;
  right: 1.5rem;
  top: 50%;
  transform: translateY(-50%);
  z-index: 40;
  display: flex;
  flex-direction: column;
  gap: 0.55rem;
  pointer-events: none;
}
.railDot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.3);
  background: transparent;
  transition: all 0.4s ease;
}
.railDot.active {
  background: var(--accent-cyan);
  border-color: var(--accent-cyan);
  box-shadow:
    0 0 10px var(--accent-cyan),
    0 0 20px rgba(90, 215, 255, 0.6);
  transform: scale(1.3);
}
@media (max-width: 720px) {
  .rail {
    display: none;
  }
}

/* ============================================================
   ENTRY HELPERS
   ============================================================ */
.fadeUp {
  opacity: 0;
  transform: translateY(40px);
}
.fadeIn {
  opacity: 0;
}

@media (prefers-reduced-motion: reduce) {
  .fadeUp,
  .fadeIn,
  .title span {
    opacity: 1 !important;
    transform: none !important;
  }
  .scanline,
  .beam,
  .particles span,
  .scrollHint::after {
    animation: none !important;
  }
}

/* ============================================================
   MOBILE / TABLET — disable pinning, let scenes flow
   GSAP pin ScrollTriggers are gated to (min-width: 1024px);
   here we reset the pin containers so content isn't clipped.
   ============================================================ */
@media (max-width: 1023px) {
  .engineWrap,
  .splitWrap,
  .triptychWrap {
    height: auto;
  }
  .enginePin,
  .splitPin,
  .triptychPin {
    position: static;
    height: auto;
    overflow: visible;
    display: block;
    padding: 4rem 0;
  }
  .splitPin {
    padding: 4rem 2rem;
  }
  .videoFrame video {
    max-height: none;
  }
  .macrosScene,
  .final {
    min-height: auto;
    padding: 4rem 2rem;
  }
  /* Triptych: stack panels naturally on mobile */
  .triptychPanels {
    position: static;
    height: auto;
    perspective: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  .recipePanel {
    position: static;
    top: auto;
    left: auto;
    transform: none !important;
    opacity: 1 !important;
    max-width: 100%;
  }
  .triptychProgress {
    display: none;
  }
}

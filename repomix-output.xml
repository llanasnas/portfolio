  aspect-ratio: 1;
  position: relative;
}
.avatar svg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  overflow: visible;
  filter: drop-shadow(0 0 12px rgba(106, 166, 255, 0.4));
  z-index: 4;
  pointer-events: none;
}
.avatarHex {
  fill: rgba(10, 12, 20, 0.32);
  stroke: rgba(106, 166, 255, 0.65);
  stroke-width: 1;
}
.avatarTick {
  stroke: rgba(168, 200, 255, 0.7);
  stroke-width: 0.8;
  stroke-linecap: round;
}
.avatarPhoto {
  position: absolute;
  inset: 6%;
  width: 88%;
  height: 88%;
  object-fit: cover;
  clip-path: polygon(50% 4%, 88% 26%, 88% 74%, 50% 96%, 12% 74%, 12% 26%);
  filter: grayscale(0.35) contrast(1.08) brightness(0.92) saturate(0.85);
  z-index: 1;
  pointer-events: none;
  user-select: none;
  -webkit-user-drag: none;
}
.avatarTint {
  position: absolute;
  inset: 6%;
  width: 88%;
  height: 88%;
  clip-path: polygon(50% 4%, 88% 26%, 88% 74%, 50% 96%, 12% 74%, 12% 26%);
  background: linear-gradient(
    135deg,
    rgba(90, 215, 255, 0.28) 0%,
    rgba(106, 166, 255, 0.22) 50%,
    rgba(184, 123, 255, 0.34) 100%
  );
  mix-blend-mode: color;
  z-index: 2;
  pointer-events: none;
}
.avatarScan {
  position: absolute;
  inset: 6%;
  width: 88%;
  height: 88%;
  clip-path: polygon(50% 4%, 88% 26%, 88% 74%, 50% 96%, 12% 74%, 12% 26%);
  background: repeating-linear-gradient(
    0deg,
    transparent 0 2px,
    rgba(168, 200, 255, 0.08) 2px 3px
  );

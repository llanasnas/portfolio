}
@keyframes tabletTyping {
  to {
    width: 100%;
  }
}
@keyframes tabletTipCaret {
  50% {
    border-right-color: transparent;
  }
}

/* ---------- Laptop folder ---------- */
.laptopZone {
  position: absolute;
  left: 73%;
  top: 64.5%;
  width: 17%;
  height: 16%;
  z-index: 6;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  perspective: 1100px;
  perspective-origin: 30% 100%;
}
.laptopFolder {
  position: absolute;
  inset: 0;
  transform-origin: 50% 100%;
  transform: rotateX(0) rotateY(-29deg) rotateZ(10deg);

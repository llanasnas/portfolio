/* HeroComponent.module.css
 * Drop next to HeroComponent.tsx. CSS Modules locally scope every class —
 * the JSX uses styles.tabletZone, styles.tabletScreen, etc.
 *
 * Keep `:global(.com)` etc for the syntax highlighting spans inside the
 * code-typing block — those are written from dangerouslySetInnerHTML
 * so they need global selectors.
 */

.hero {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  isolation: isolate;
  cursor: default;
  font-family: "Inter", system-ui, sans-serif;
  color: #c8cde6;
  -webkit-font-smoothing: antialiased;
  /* Cyberpunk bg visible cuando la imagen no llena el viewport */
  background-color: #03040c;
  background-image: url("/assets/cv_bg.webp") center center;
}
.stage {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  /* contain: la imagen siempre se ve entera; los elementos % siguen alineados */
  width: min(100vw, calc(100vh * 1.5));
  aspect-ratio: 1536 / 1024;
}
.stagePhoto {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: fill; /* stage ya tiene el aspect-ratio exacto de la foto */
  filter: brightness(0.86) contrast(1.04) saturate(0.95);
  pointer-events: none;
  user-select: none;
  -webkit-user-drag: none;
}
.stageVignette {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(
      130% 95% at 50% 55%,
      transparent 40%,
      rgba(0, 0, 0, 0.5) 100%
    ),
    linear-gradient(
      0deg,
      rgba(2, 3, 8, 0.45) 0%,
      transparent 25%,
      transparent 75%,
      rgba(8, 10, 18, 0.3) 100%
    );
  z-index: 1;
}

/* ---------- Tablet code surface ---------- */
.tabletZone {
  z-index: 5;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  perspective: 900px;
  perspective-origin: 50% 0;
  width: 22%;
  height: 20.9%;
  position: absolute;
  top: 79.4%;
  left: 42.9%;
}
.tabletScreen {
  position: absolute;
  inset: 0;
  transform-origin: 50% 0%;
  transform: rotateX(62deg) rotateY(11.3deg) rotateZ(-25deg);

  border-radius: 4px;
  overflow: hidden;

  transition:
    box-shadow 600ms cubic-bezier(0.22, 1, 0.36, 1),
    filter 600ms cubic-bezier(0.22, 1, 0.36, 1);
}
.tabletScreen::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(
    80% 90% at 50% 0%,
    rgba(106, 166, 255, 0.08),
    transparent 60%
  );
  pointer-events: none;
}
.tabletZone:hover .tabletScreen,
.tabletZone.touch .tabletScreen {
  box-shadow:
    0 0 0 3px rgba(106, 166, 255, 0.3) inset,
    0 0 24px rgba(106, 166, 255, 0.22),
    0 24px 60px -8px rgba(0, 0, 0, 0.65);
  filter: brightness(8.18);
}
.tabletSpill {
  position: absolute;
  left: -10%;
  right: -10%;
  top: 105%;
  height: 90%;
  pointer-events: none;
  background: radial-gradient(
    50% 60% at 50% 0%,
    rgba(106, 166, 255, 0.45),
    rgba(184, 123, 255, 0.25) 45%,
    transparent 75%
  );
  filter: blur(20px);
  opacity: 0;
  transition: opacity 600ms cubic-bezier(0.22, 1, 0.36, 1);
  mix-blend-mode: screen;
  z-index: -1;
}
.tabletZone:hover .tabletSpill,
.tabletZone.touch .tabletSpill {
  opacity: 0.85;
}
.tabletCode {
  position: absolute;
  inset: 0;
  padding: 14px 16px 18px 16px;
  font-family: "JetBrains Mono", ui-monospace, monospace;
  font-size: 11.5px;
  line-height: 1.55;
  color: #c8cde6;
  white-space: pre;
  overflow: hidden;
}
.ln {
  display: block;
  opacity: 0.92;
}
/* Globals are needed because these classes come from dangerouslySetInnerHTML */
:global(.com) {
  color: #5a6082;
}
:global(.kw) {
  color: #b87bff;
}
:global(.fn) {
  color: #5ad7ff;
}
:global(.str) {
  color: #a8e6c9;
}
:global(.num) {
  color: #fbbf24;
}
:global(.pl) {
  color: #c8cde6;
}
:global(.pn) {
  color: #5a6082;
}

.tabletCursor {
  display: inline-block;
  width: 7px;
  height: 1em;
  vertical-align: -2px;
  background: #5ad7ff;
  margin-left: 2px;
  animation: blink 1s steps(2) infinite;
  box-shadow: 0 0 6px #5ad7ff;
}
@keyframes blink {
  50% {
    opacity: 0;
  }
}

.tabletTab {
  position: absolute;
  top: 0;
  left: 8px;
  font-family: "JetBrains Mono", ui-monospace, monospace;
  font-size: 9px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #8a90ad;
  padding: 4px 10px;
  border-bottom: 1px solid rgba(106, 166, 255, 0.35);
  background: rgba(106, 166, 255, 0.06);
}
.dot {
  display: inline-block;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #5ad7ff;
  margin-right: 6px;
  box-shadow: 0 0 6px #5ad7ff;
  vertical-align: 1px;
}
.tabletHint {
  position: absolute;
  bottom: 6px;
  right: 12px;
  font-family: "JetBrains Mono", ui-monospace, monospace;
  font-size: 9px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #5a6082;
  opacity: 0;
  transition: opacity 500ms cubic-bezier(0.22, 1, 0.36, 1);
}
.tabletZone:hover .tabletHint {
  opacity: 0.85;
}

/* ---------- Tablet tooltip (curved lateral HUD) ---------- */
.tabletTooltip {
  position: absolute;
  left: 86%;
  top: 42%;
  min-width: 150px;
  padding: 7px 10px 8px;
  font-family: "JetBrains Mono", ui-monospace, monospace;
  font-size: clamp(8px, 0.68vw, 10px);
  line-height: 1.55;
  letter-spacing: 0.06em;
  color: var(--fg-2, #c8cde6);
  background:
    radial-gradient(
      130% 120% at 12% 50%,
      rgba(106, 166, 255, 0.14) 0%,
      transparent 45%
    ),
    rgba(10, 12, 20, 0.72);
  border: 1px solid rgba(106, 166, 255, 0.3);
  border-radius: 12px 18px 18px 12px;
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  box-shadow:
    0 0 18px rgba(106, 166, 255, 0.18),
    0 8px 24px -8px rgba(0, 0, 0, 0.62),
    0 0 0 1px rgba(90, 215, 255, 0.08) inset;
  opacity: 0;
  pointer-events: none;
  white-space: nowrap;
  z-index: 7;
  transform-origin: 0 50%;
  transform: rotateX(42deg) rotateY(-36deg) rotateZ(-16deg) translateX(-8px)
    translateY(-2px);
  transition:
    opacity 360ms cubic-bezier(0.22, 1, 0.36, 1),
    transform 360ms cubic-bezier(0.22, 1, 0.36, 1);
}
.tabletTooltip::before {
  content: "";
  position: absolute;
  left: -7px;
  top: 50%;
  width: 14px;
  height: 14px;
  background: rgba(10, 12, 20, 0.72);
  border-left: 1px solid rgba(106, 166, 255, 0.3);

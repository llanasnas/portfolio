<file path="components/projects/travel-agency/TravelAgencyStory.module.css">
/* ============================================================
   TRAVEL AGENCY — cinematic case study (cyberpunk)
   Palette twist: cyan / amber (warmth) / violet
   ============================================================ */

.root {
  position: relative;
  background: #04050a;
  color: var(--fg-1);
  overflow: hidden;
  isolation: isolate;
}

.root::before {
  content: "";
  position: fixed;
  inset: 0;
  background:
    radial-gradient(
      60% 50% at 15% 8%,
      rgba(90, 215, 255, 0.16) 0%,
      transparent 70%
    ),
    radial-gradient(
      50% 50% at 100% 5%,
      rgba(251, 191, 36, 0.1) 0%,
      transparent 70%
    ),
    radial-gradient(
      70% 60% at 50% 100%,
      rgba(184, 123, 255, 0.1) 0%,
      transparent 75%
    );
  pointer-events: none;
  z-index: 0;
}

.grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(90, 215, 255, 0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(90, 215, 255, 0.06) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(
    ellipse 80% 70% at 50% 50%,
    #000 30%,
    transparent 80%
  );
  pointer-events: none;
  z-index: 1;
}

.particles {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 1;
  overflow: hidden;
}
.particles span {
  position: absolute;
  display: block;
  width: 2px;
  height: 2px;
  border-radius: 50%;
  background: var(--accent-cyan);
  box-shadow:
    0 0 8px var(--accent-cyan),
    0 0 14px rgba(90, 215, 255, 0.6);
  animation: float linear infinite;
  opacity: 0.7;
}
.particles span:nth-child(3n) {
  background: var(--warning);
  box-shadow:
    0 0 10px var(--warning),
    0 0 18px rgba(251, 191, 36, 0.55);
}
.particles span:nth-child(5n) {
  background: var(--accent-violet);
  box-shadow:
    0 0 10px var(--accent-violet),
    0 0 18px rgba(184, 123, 255, 0.55);
}
@keyframes float {
  0% {
    transform: translate3d(0, 100vh, 0) scale(0.6);
    opacity: 0;
  }
  20% {
    opacity: 0.9;
  }
  100% {
    transform: translate3d(40px, -10vh, 0) scale(1);
    opacity: 0;
  }
}

.beams {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}
.beam {
  position: absolute;
  top: -20%;
  width: 2px;
  height: 140%;
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(90, 215, 255, 0.5) 50%,
    transparent 100%
  );
  filter: blur(1px);
  animation: beamSweep 8s ease-in-out infinite;
}
.beam:nth-child(1) {
  left: 12%;
  animation-delay: 0s;
}
.beam:nth-child(2) {
  left: 40%;
  animation-delay: 1.6s;
  background: linear-gradient(
    180deg,
    transparent,
    rgba(251, 191, 36, 0.45),
    transparent
  );
}
.beam:nth-child(3) {
  left: 68%;
  animation-delay: 3.2s;
}
.beam:nth-child(4) {
  left: 88%;
  animation-delay: 4.8s;
  background: linear-gradient(
    180deg,
    transparent,
    rgba(184, 123, 255, 0.45),
    transparent
  );
}
@keyframes beamSweep {
  0%,
  100% {
    opacity: 0;
    transform: translateY(-20px) scaleY(0.6);
  }
  50% {
    opacity: 1;
    transform: translateY(20px) scaleY(1);
  }
}

/* ============================================================
   HERO
   ============================================================ */
.hero {
  position: relative;
  min-height: 100vh;
  display: grid;
  justify-items: center;
  align-content: start;
  padding: calc(var(--header-h, 56px) + 3rem) 1.5rem 4rem;
  text-align: center;
}
.heroInner {
  position: relative;
  z-index: 3;
  max-width: 1200px;
  width: 100%;
}

.kicker {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: var(--warning);
  padding: 0.5rem 1rem;
  border: 1px solid rgba(251, 191, 36, 0.35);
  border-radius: 999px;
  background: rgba(251, 191, 36, 0.06);
  backdrop-filter: blur(10px);
  margin-bottom: 1.2rem;
}
.kicker::before {
  content: "";
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--warning);
  box-shadow: 0 0 10px var(--warning);
  animation: pulseDot 1.8s ease-in-out infinite;
}
@keyframes pulseDot {
  0%,
  100% {
    opacity: 0.5;
    transform: scale(0.9);
  }
  50% {
    opacity: 1;
    transform: scale(1.2);
  }
}

.brandIcon {
  width: 88px;
  height: 88px;
  margin: 0 auto 1.2rem;
  filter: drop-shadow(0 0 16px rgba(90, 215, 255, 0.45))
    drop-shadow(0 0 40px rgba(251, 191, 36, 0.3));
}

.title {
  font-family: var(--font-sans);
  font-size: clamp(3.2rem, 12vw, 11rem);
  font-weight: 800;
  letter-spacing: -0.04em;
  line-height: 0.92;
  display: none;
  margin: 0;
  position: absolute;
  background: linear-gradient(180deg, #fff 0%, #fce7b8 45%, #5ad7ff 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  filter: drop-shadow(0 0 40px rgba(90, 215, 255, 0.32))
    drop-shadow(0 0 80px rgba(251, 191, 36, 0.18));
}
.title span {
  display: inline-block;
  transform: translateY(120%);
  opacity: 0;
}

.subtitle {
  margin: 1.6rem auto 0;
  max-width: 740px;
  font-size: clamp(1.05rem, 2vw, 1.4rem);
  color: var(--fg-2);
  font-weight: 300;
}
.desc {
  margin: 1.1rem auto 0;
  max-width: 660px;
  font-size: 0.95rem;
  color: var(--fg-3);
  line-height: 1.7;
}
.heroButtons {
  margin-top: 2rem;
  display: inline-flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.9rem;
}

.heroPreview {
  position: relative;
  margin: 3rem auto 0;
  max-width: 1100px;
  perspective: 1800px;
  z-index: 3;
}
.heroPreviewInner {
  position: relative;
  border-radius: 18px;
  overflow: hidden;
  transform-style: preserve-3d;
  border: 1px solid rgba(90, 215, 255, 0.35);
  box-shadow:
    0 30px 80px rgba(0, 0, 0, 0.7),
    0 0 80px rgba(90, 215, 255, 0.25),
    0 0 160px rgba(251, 191, 36, 0.12);
  will-change: transform;
  background: #0a0c14;
}
.heroPreviewInner img {
  display: block;
  width: 100%;
  height: auto;
}

/* HUD corners */
.hudCorner {
  position: absolute;
  width: 26px;
  height: 26px;
  border: 1.5px solid var(--accent-cyan);
  opacity: 0.75;
  filter: drop-shadow(0 0 8px var(--accent-cyan));
}
.hudCorner.tl {
  top: 10px;
  left: 10px;
  border-right: 0;
  border-bottom: 0;
}
.hudCorner.tr {
  top: 10px;
  right: 10px;
  border-left: 0;
  border-bottom: 0;
}
.hudCorner.bl {
  bottom: 10px;
  left: 10px;
  border-right: 0;
  border-top: 0;
}
.hudCorner.br {
  bottom: 10px;
  right: 10px;
  border-left: 0;
  border-top: 0;
}

.scrollHint {
  position: absolute;
  left: 50%;
  bottom: 1.6rem;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.6rem;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.3em;
  color: var(--fg-3);
  z-index: 4;
}
.scrollHint::after {
  content: "";
  width: 1px;
  height: 38px;
  background: linear-gradient(180deg, var(--accent-cyan), transparent);
  animation: scrollLine 2s ease-in-out infinite;
}
@keyframes scrollLine {
  0%,
  100% {
    transform: scaleY(0.4);
    transform-origin: top;
    opacity: 0.4;
  }
  50% {
    transform: scaleY(1);
    opacity: 1;
  }
}

/* ============================================================
   HEADINGS / LABELS
   ============================================================ */
.sectionLabel {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--accent-cyan);
  margin-bottom: 1rem;
  display: inline-block;
  padding: 0.35rem 0.75rem;
  border-left: 2px solid var(--accent-cyan);
}
.sectionLabel.violet {
  color: var(--accent-violet);
  border-color: var(--accent-violet);
}
.sectionLabel.warning {
  color: var(--warning);
  border-color: var(--warning);
}
.sectionLabel.green {
  color: var(--success);
  border-color: var(--success);
}

.h2 {
  font-size: clamp(2.2rem, 4.6vw, 4.4rem);
  font-weight: 700;
  line-height: 1.02;
  letter-spacing: -0.025em;
  margin: 0 0 1.4rem;
  background: linear-gradient(180deg, #fff, #a8c8ff);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
.lead {
  font-size: 1.05rem;
  color: var(--fg-2);
  line-height: 1.7;
  max-width: 560px;
}
.featureList {
  list-style: none;
  padding: 0;
  margin: 1.5rem 0 0;
  display: grid;
  gap: 0.7rem;
}
.featureList li {
  display: flex;
  align-items: flex-start;
  gap: 0.7rem;
  font-size: 0.95rem;
  color: var(--fg-2);
}
.featureList li::before {
  content: "";
  flex-shrink: 0;
  width: 14px;
  height: 14px;
  margin-top: 4px;
  border: 1.5px solid var(--accent-cyan);
  background: rgba(90, 215, 255, 0.1);
  box-shadow: 0 0 10px rgba(90, 215, 255, 0.45);
  transform: rotate(45deg);
}

/* ============================================================
   PINNED SPLIT — for scrubbed scenes (dashboard, itineraries, etc.)
   ============================================================ */
.splitWrap {
  position: relative;
  height: 300vh;
}
.splitPin {
  position: sticky;
  top: 0;
  height: 100vh;
  display: grid;
  grid-template-columns: 1fr;
  align-items: center;
  overflow: hidden;
}

.split {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding: 6rem 2rem;
}
.splitInner {
  width: 100%;
  max-width: 1500px;
  margin: 0 auto;
  padding: 0 2rem;
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: center;
}
@media (min-width: 1024px) {
  .splitInner {
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
  }
  .splitInner.reverse {
    direction: rtl;
  }
  .splitInner.reverse > * {
    direction: ltr;
  }
  .splitInner.wideImg {
    grid-template-columns: 0.85fr 1.55fr;
  }
}

.shotFrame {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow:
    0 30px 80px rgba(0, 0, 0, 0.7),
    0 0 60px var(--shotGlow, rgba(90, 215, 255, 0.25));
  will-change: transform;
  background: #000;
}
.shotFrame img {
  display: block;
  width: 100%;
  height: auto;
}
.shotGlow {
  position: absolute;
  inset: -20%;
  background: radial-gradient(
    circle,
    var(--shotGlow, rgba(90, 215, 255, 0.35)) 0%,
    transparent 60%
  );
  pointer-events: none;
  z-index: -1;
  filter: blur(40px);
}

.scanline {
  position: absolute;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(
    90deg,
    transparent,
    var(--accent-cyan),
    transparent
  );
  filter: blur(1px);
  box-shadow:
    0 0 12px var(--accent-cyan),
    0 0 28px rgba(90, 215, 255, 0.6);
  animation: scanY 3.4s ease-in-out infinite;
  pointer-events: none;
}
@keyframes scanY {
  0% {
    top: 0;
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    top: 100%;
    opacity: 0;
  }
}
.frameEdge {
  position: absolute;
  inset: 0;
  pointer-events: none;
  border-radius: inherit;
  box-shadow:
    inset 0 0 0 1px rgba(90, 215, 255, 0.18),
    inset 0 0 40px rgba(90, 215, 255, 0.08),
    inset 0 0 80px rgba(251, 191, 36, 0.06);
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin: 1.4rem 0 0.5rem;
}
.tag {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  padding: 0.4rem 0.75rem;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.03);
  color: var(--fg-2);
}

.copy {
  position: relative;
  z-index: 2;
}
.copy p {
  margin: 0;
  color: var(--fg-2);
  line-height: 1.7;
  font-size: 1rem;
}
.copy p + p {
  margin-top: 1rem;
}

.callout {
  margin-top: 1.4rem;
  padding: 1.1rem 1.3rem;
  border-left: 2px solid var(--accent-cyan);
  background: linear-gradient(90deg, rgba(90, 215, 255, 0.08), transparent);
  font-size: 0.88rem;
  color: var(--fg-2);
  border-radius: 0 8px 8px 0;
}
.callout.violet {
  border-left-color: var(--accent-violet);
  background: linear-gradient(90deg, rgba(184, 123, 255, 0.08), transparent);
}
.callout.warning {
  border-left-color: var(--warning);
  background: linear-gradient(90deg, rgba(251, 191, 36, 0.08), transparent);
}
.callout.green {
  border-left-color: var(--success);
  background: linear-gradient(90deg, rgba(74, 222, 128, 0.08), transparent);
}

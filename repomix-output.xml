.gate {
  position: fixed;
  inset: 0;
  z-index: 50;
  pointer-events: none;
  overflow: hidden;
  isolation: isolate;
  animation: arrivalFade 0.75s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.flash {
  position: absolute;
  inset: -10%;
  background: radial-gradient(
    60% 60% at 50% 50%,
    rgba(220, 245, 255, 0.85) 0%,
    rgba(90, 215, 255, 0.6) 25%,
    rgba(139, 123, 255, 0.25) 55%,
    transparent 80%
  );
  mix-blend-mode: screen;
  animation: flashShrink 0.75s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.scan {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    0deg,
    rgba(168, 200, 255, 0.2) 0 2px,
    transparent 2px 4px
  );
  mix-blend-mode: screen;
  transform: translateY(0);
  animation: scanRetract 0.75s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);

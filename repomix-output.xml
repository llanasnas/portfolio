  white-space: nowrap;
  margin-top: 1px;
}
.tabletZone:hover .tabletTooltip,
.tabletZone:focus-visible .tabletTooltip,
.tabletZone.touch .tabletTooltip {
  opacity: 1;
  transform: rotateX(42deg) rotateY(-36deg) rotateZ(-16deg) translateX(0)
    translateY(0);
}
.tabletZone:hover .tabletTipLine2,
.tabletZone:focus-visible .tabletTipLine2,
.tabletZone.touch .tabletTipLine2 {
  animation:
    tabletTyping 1.1s steps(24, end) forwards 0.12s,

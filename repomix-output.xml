  margin-bottom: 0.35rem;
}
.callout.violet strong {
  color: var(--accent-violet, #b87bff);
}
.callout.green strong {
  color: var(--success, #4ade80);
}

/* ── Shot frame (used by plugin + admin) ── */
.shotFrame {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(168, 85, 247, 0.35);
  box-shadow:
    0 40px 100px rgba(0, 0, 0, 0.7),
    0 0 60px rgba(168, 85, 247, 0.22);
  will-change: transform;
  background: #0a0c14;
}
.shotFrame img {
  position: relative;
  z-index: 2;
  display: block;
  width: 100%;
  height: auto;
  max-height: 80vh;
  object-fit: contain;
  background: #0a0c14;
}
.scanline {
  position: absolute;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(
    90deg,
    transparent,
    var(--accent-violet, #b87bff),
    transparent
  );
  filter: blur(1px);
  box-shadow:
    0 0 12px var(--accent-violet, #b87bff),
    0 0 28px rgba(184, 123, 255, 0.55);
  animation: scanY 3.4s ease-in-out infinite;
  pointer-events: none;
  z-index: 3;
}
@keyframes scanY {
  0% {
    top: 0;
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    top: 100%;
    opacity: 0;
  }
}
.frameEdge {
  position: absolute;
  inset: 0;
  pointer-events: none;
  border-radius: inherit;
  box-shadow:
    inset 0 0 0 1px rgba(168, 85, 247, 0.18),
    inset 0 0 40px rgba(168, 85, 247, 0.08),
    inset 0 0 80px rgba(90, 215, 255, 0.06);
  z-index: 4;
}
.mockupBg {
  position: absolute;
  inset: 0;
  z-index: 1;
  opacity: 0.18;
  pointer-events: none;
  display: grid;
  place-items: center;
}
.mockupSvg {
  width: 90%;
  height: auto;
  color: rgba(168, 85, 247, 0.6);
}

/* ============================================================
   FLOW LIST (admin scene)
   ============================================================ */
.flowList {
  list-style: none;
  margin: 1.5rem 0 0;
  padding: 0;
  display: grid;
  gap: 0.7rem;
}
.flowList li {
  display: flex;
  align-items: flex-start;
  gap: 0.85rem;
  padding: 0.85rem 1rem;
  border-radius: 12px;
  border: 1px solid rgba(74, 222, 128, 0.2);
  background: rgba(74, 222, 128, 0.04);
}
.flowList li div {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}
.flowList strong {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--fg-1);
}
.flowList span {
  font-size: 0.85rem;
  color: var(--fg-3);
}
.flowNum {
  flex-shrink: 0;
  width: 28px;
  height: 28px;
  border-radius: 8px;
  display: grid;
  place-items: center;
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--success, #4ade80);
  background: rgba(74, 222, 128, 0.1);
  border: 1px solid rgba(74, 222, 128, 0.4);
}

/* ============================================================
   SECURITY
   ============================================================ */
.security {
  position: relative;
  padding: 14rem 2rem 8rem;
}
.securityInner {
  max-width: 1500px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: start;
}
@media (min-width: 1024px) {
  .securityInner {
    grid-template-columns: 1fr 1.2fr;
    gap: 4.5rem;
  }
}
.secGrid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}
@media (min-width: 640px) {
  .secGrid {
    grid-template-columns: 1fr 1fr;
  }
}
.secCard {
  padding: 1.3rem 1.2rem;
  border-radius: 14px;
  border: 1px solid rgba(74, 222, 128, 0.22);
  background:
    linear-gradient(135deg, rgba(74, 222, 128, 0.04), rgba(90, 215, 255, 0.03)),
    rgba(10, 12, 20, 0.5);
  backdrop-filter: blur(10px);
}
.secCard svg {
  color: var(--success, #4ade80);
}
.secCard h5 {
  margin: 0.7rem 0 0.4rem;
  font-size: 0.95rem;
  font-family: var(--font-mono);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--fg-1);
}
.secCard p {
  margin: 0;
  font-size: 0.86rem;
  color: var(--fg-2);
  line-height: 1.6;
}
.secCard code {
  font-family: var(--font-mono);
  font-size: 0.78rem;
  padding: 0.1rem 0.35rem;
  border-radius: 4px;
  background: rgba(168, 85, 247, 0.12);
  color: var(--accent-violet, #b87bff);
  border: 1px solid rgba(168, 85, 247, 0.25);
}

/* ============================================================
   STACK
   ============================================================ */
.stack {
  position: relative;
  padding: 8rem 2rem;
}
.stackInner {
  max-width: 1400px;
  margin: 0 auto;
  text-align: center;
}
.stackGrid {
  margin-top: 3rem;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.9rem;
}
@media (min-width: 720px) {
  .stackGrid {
    grid-template-columns: repeat(4, 1fr);
  }
}
@media (min-width: 1024px) {
  .stackGrid {
    grid-template-columns: repeat(6, 1fr);
  }
}
.stackChip {
  padding: 1rem 0.7rem;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.025);
  backdrop-filter: blur(10px);
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.12em;
  color: var(--fg-2);
  text-transform: uppercase;
  transition:
    border-color 0.3s ease,
    color 0.3s ease,
    box-shadow 0.3s ease;
}
.stackChip:hover {
  border-color: rgba(168, 85, 247, 0.5);
  color: var(--accent-violet, #b87bff);
  box-shadow: 0 0 18px rgba(168, 85, 247, 0.22);
}

/* ============================================================
   FINAL CTA
   ============================================================ */
.final {
  position: relative;
  min-height: 100vh;
  display: grid;
  place-items: center;
  padding: 6rem 2rem;
  text-align: center;
  overflow: hidden;
}
.finalInner {
  position: relative;
  z-index: 3;
  max-width: 1100px;
}
.finalKicker {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.3em;
  color: var(--accent-violet, #b87bff);
  text-transform: uppercase;
  margin-bottom: 1.4rem;
}
.finalTitle {
  font-size: clamp(2.6rem, 10vw, 9rem);
  font-weight: 800;
  letter-spacing: -0.04em;
  line-height: 0.92;
  margin: 0;
  background: linear-gradient(180deg, #fff 0%, #d8c8ff 40%, #a855f7 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  filter: drop-shadow(0 0 60px rgba(168, 85, 247, 0.4))
    drop-shadow(0 0 120px rgba(90, 215, 255, 0.15));
}
.finalSubtitle {
  margin: 1.4rem auto 2rem;
  max-width: 720px;
  color: var(--fg-2);
  font-size: clamp(1rem, 1.6vw, 1.2rem);
  line-height: 1.7;
}
.finalCards {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
  max-width: 820px;
  margin: 0 auto 2.5rem;
}
@media (min-width: 720px) {
  .finalCards {
    grid-template-columns: repeat(3, 1fr);
  }
}
.finalCard {
  padding: 1.3rem 1.1rem;
  border-radius: 14px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.025);
  backdrop-filter: blur(14px);
  text-align: left;
}
.finalCard h5 {
  margin: 0 0 0.5rem;
  font-size: 0.82rem;
  font-family: var(--font-mono);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--accent-violet, #b87bff);
}
.finalCard p {
  margin: 0;
  color: var(--fg-2);
  font-size: 0.88rem;
  line-height: 1.6;
}

/* ============================================================
   CTA buttons
   ============================================================ */
.ctaRow {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: stretch;
  gap: 1rem;
}
.cta {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 0.8rem;
  padding: 1rem 1.6rem;
  font-family: var(--font-mono);
  font-size: 0.82rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #fff;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: linear-gradient(
    135deg,
    rgba(168, 85, 247, 0.95),
    rgba(90, 215, 255, 0.9)
  );
  box-shadow:
    0 18px 40px rgba(168, 85, 247, 0.4),
    0 0 60px rgba(90, 215, 255, 0.28),
    inset 0 1px 0 rgba(255, 255, 255, 0.2);
  transition:
    transform 0.3s var(--ease-spring),
    box-shadow 0.3s ease;
  text-decoration: none;
  overflow: hidden;
  isolation: isolate;
}
.cta::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    120deg,
    transparent 0%,
    rgba(255, 255, 255, 0.18) 50%,
    transparent 100%
  );
  transform: translateX(-100%);
  transition: transform 0.7s ease;
  z-index: -1;
}
.cta:hover {
  transform: translateY(-2px) scale(1.02);
  box-shadow:
    0 24px 60px rgba(168, 85, 247, 0.55),
    0 0 80px rgba(90, 215, 255, 0.4),
    inset 0 1px 0 rgba(255, 255, 255, 0.25);
}
.cta:hover::before {
  transform: translateX(100%);
}
.cta:hover .ctaArrow {
  transform: translateX(4px);
}
.ctaArrow {
  transition: transform 0.3s var(--ease-spring);
}
.ctaGhost {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 0.85rem;
  padding: 0.95rem 1.4rem;
  border-radius: 999px;
  border: 1px solid rgba(168, 85, 247, 0.4);
  background: linear-gradient(
    135deg,
    rgba(168, 85, 247, 0.06),
    rgba(90, 215, 255, 0.04)
  );
  backdrop-filter: blur(14px);
  color: var(--fg-1);
  text-decoration: none;
  font-family: var(--font-mono);
  font-size: 0.78rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  transition:
    transform 0.3s var(--ease-spring),
    border-color 0.3s ease,
    box-shadow 0.3s ease,
    background 0.3s ease;
}
.ctaGhost:hover {
  transform: translateY(-2px);
  border-color: rgba(168, 85, 247, 0.7);
  box-shadow:
    0 18px 40px rgba(168, 85, 247, 0.22),
    0 0 40px rgba(168, 85, 247, 0.2);
}
.ctaGhost svg {
  color: var(--accent-violet, #b87bff);
}
@media (max-width: 560px) {
  .ctaRow {
    flex-direction: column;
    align-items: stretch;
    gap: 0.85rem;
  }
  .cta,
  .ctaGhost {
    justify-content: center;
  }
}

/* ============================================================
   PROGRESS RAIL
   ============================================================ */
.rail {
  position: fixed;
  right: 1.5rem;
  top: 50%;
  transform: translateY(-50%);
  z-index: 40;
  display: flex;
  flex-direction: column;
  gap: 0.55rem;
  pointer-events: none;
}
.railDot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.3);
  background: transparent;
  transition: all 0.4s ease;
}
.railDot.active {
  background: var(--accent-violet, #b87bff);
  border-color: var(--accent-violet, #b87bff);
  box-shadow:
    0 0 10px var(--accent-violet, #b87bff),
    0 0 20px rgba(184, 123, 255, 0.55);
  transform: scale(1.3);
}
@media (max-width: 720px) {
  .rail {
    display: none;
  }
}

/* ============================================================
   ENTRY HELPERS
   ============================================================ */
.fadeUp {
  opacity: 0;
  transform: translateY(40px);
}
.fadeIn {
  opacity: 0;
}

@media (prefers-reduced-motion: reduce) {
  .fadeUp,
  .fadeIn,
  .title span {
    opacity: 1 !important;
    transform: none !important;
  }
  .scanline,
  .beam,
  .particles span,
  .scrollHint::after {
    animation: none !important;
  }
}

/* ============================================================
   MOBILE / TABLET — disable pinning, let scenes flow
   GSAP pin ScrollTriggers are gated to (min-width: 1024px);
   here we reset the pin containers so content isn't clipped.
   ============================================================ */
@media (max-width: 1023px) {
  .pinWrap {
    height: auto;
  }
  .pinInner {
    position: static;
    height: auto;
    overflow: visible;
    display: block;
    padding: 4rem 1.5rem;
  }
  .shotFrame img {
    max-height: none;
  }
  .ecosystem,
  .craft,
  .security,
  .stack,
  .final {
    padding: 4rem 1.5rem;
  }
  .security,
  .final {
    min-height: auto;
  }
}
</file>


<file path="components/heroSection/HoloSocials.module.css">
/* HoloSocials.module.css — floating holographic social entities
 * GPU-friendly: transform + opacity only in idle loops.
 */

.stack {
  position: absolute;
  right: 4%;
  top: 22%;
  width: 11%;
  height: 46%;
  z-index: 7;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 14%;
  pointer-events: none;
  /* parallax driver — local, no :root writes */
  --mx: 0;
  --my: 0;
  transform: translate3d(
    calc(var(--mx) * -6px),
    calc(var(--my) * -6px),
    0
  );
  transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
}

.item {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  pointer-events: auto;
  display: block;
  transform-style: preserve-3d;
  transform: perspective(900px) rotateY(-8deg) rotateX(2deg);
  transition:
    transform 420ms cubic-bezier(0.22, 1, 0.36, 1),
    filter 420ms cubic-bezier(0.22, 1, 0.36, 1);
  outline: none;
  text-decoration: none;
  animation:
    float 7s ease-in-out infinite,
    flicker 12s steps(60, end) infinite;
  will-change: transform, opacity;
}
.item:nth-child(2) {
  animation-delay: -3.4s, -5.2s;
}

.item:focus-visible {
  outline: 2px solid var(--accent-cyan, #5ad7ff);
  outline-offset: 6px;
  border-radius: 6px;
}

/* ----- Halo glow ----- */
.glow {
  position: absolute;
  inset: -22%;
  pointer-events: none;
  background: radial-gradient(
    50% 50% at calc(50% + var(--mx) * 10px) calc(50% + var(--my) * 10px),
    rgba(139, 123, 255, 0.55) 0%,
    rgba(106, 166, 255, 0.32) 35%,
    rgba(90, 215, 255, 0.12) 60%,
    transparent 78%
  );
  filter: blur(14px);
  mix-blend-mode: screen;
  opacity: 0.55;
  z-index: 0;
  animation: breath 4.6s ease-in-out infinite;
  will-change: opacity;
}
.item:nth-child(2) .glow {
  animation-delay: -2.1s;
}

/* ----- Particle dots overlay ----- */
.particles {
  position: absolute;
  inset: 8%;
  pointer-events: none;
  background-image:
    radial-gradient(circle at 50% 50%, rgba(168, 200, 255, 0.85) 0.6px, transparent 1.1px),
    radial-gradient(circle at 50% 50%, rgba(184, 123, 255, 0.55) 0.5px, transparent 1px);
  background-size: 9px 9px, 14px 14px;
  background-position: 0 0, 4px 6px;
  opacity: 0.45;
  mix-blend-mode: screen;
  z-index: 1;
  transform: translate3d(0, 0, 0);
  animation: drift 9s ease-in-out infinite;
  -webkit-mask-image: radial-gradient(circle at 50% 50%, #000 35%, transparent 72%);
  mask-image: radial-gradient(circle at 50% 50%, #000 35%, transparent 72%);
}

/* ----- SVG layer: hex frame + logo ----- */
.svg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  overflow: visible;
  pointer-events: none;
  transition: filter 420ms cubic-bezier(0.22, 1, 0.36, 1);
  filter: drop-shadow(0 0 6px rgba(106, 166, 255, 0.35));
}
.hex {
  fill: rgba(10, 12, 20, 0.18);
  stroke: rgba(106, 166, 255, 0.55);
  stroke-width: 0.8;
}
.tick {
  stroke: rgba(168, 200, 255, 0.7);
  stroke-width: 0.7;
  stroke-linecap: round;
}
.logo {
  fill: none;
  stroke: var(--accent-cyan, #5ad7ff);
  stroke-width: 1.4;
  stroke-linejoin: round;
  stroke-linecap: round;
}
.logoFill {
  fill: rgba(90, 215, 255, 0.06);
  stroke: none;
}

/* ----- Scanlines (hover only) ----- */
.scan {
  position: absolute;
  inset: 8%;
  pointer-events: none;
  background: repeating-linear-gradient(
    0deg,
    rgba(168, 200, 255, 0.12) 0px,
    rgba(168, 200, 255, 0.12) 1px,
    transparent 1px,
    transparent 3px
  );
  opacity: 0;
  z-index: 3;
  mix-blend-mode: screen;
  border-radius: 50%;
  -webkit-mask-image: radial-gradient(circle at 50% 50%, #000 55%, transparent 78%);
  mask-image: radial-gradient(circle at 50% 50%, #000 55%, transparent 78%);
  transition: opacity 360ms cubic-bezier(0.22, 1, 0.36, 1);
}

/* ----- Ripple (single shot on hover) ----- */
.ripple {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 10%;
  height: 10%;
  border-radius: 50%;
  border: 1px solid rgba(168, 200, 255, 0.6);
  opacity: 0;
  pointer-events: none;
  z-index: 2;
  transform: translate(-50%, -50%) scale(1);
}

/* ----- Tooltip terminal ----- */
.tooltip {
  position: absolute;
  right: 112%;
  top: 50%;
  transform: translate(8px, -50%);
  min-width: 168px;
  padding: 8px 12px 9px;
  font-family: "JetBrains Mono", ui-monospace, monospace;
  font-size: 10px;
  line-height: 1.55;
  letter-spacing: 0.06em;
  color: var(--fg-2, #c8cde6);
  background: rgba(10, 12, 20, 0.72);
  border: 1px solid rgba(106, 166, 255, 0.28);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  box-shadow:
    0 0 0 1px rgba(90, 215, 255, 0.06) inset,
    0 8px 24px -8px rgba(0, 0, 0, 0.6),
    0 0 18px rgba(106, 166, 255, 0.18);
  clip-path: polygon(
    0 8%,
    8% 0,
    100% 0,
    100% 88%,
    92% 100%,
    0 100%
  );
  opacity: 0;
  pointer-events: none;
  white-space: nowrap;
  z-index: 12;
  transition:
    opacity 360ms cubic-bezier(0.22, 1, 0.36, 1),
    transform 360ms cubic-bezier(0.22, 1, 0.36, 1);
}
.tipLine1 {
  display: block;
  color: var(--accent-cyan, #5ad7ff);
  opacity: 0.95;
}
.tipLine2 {
  display: block;
  overflow: hidden;
  width: 0;
  color: var(--fg-3, #8a90ad);
  border-right: 1px solid transparent;
  white-space: nowrap;
  margin-top: 1px;
}

/* ----- Hover state ----- */
.item:hover,
.item:focus-visible {
  transform: perspective(900px) rotateY(-12deg) rotateX(4deg) scale(1.06);
}
.item:hover .svg,
.item:focus-visible .svg {
  filter: drop-shadow(0 0 10px rgba(184, 123, 255, 0.6))
    drop-shadow(0 0 4px rgba(90, 215, 255, 0.5));
}
.item:hover .hex,
.item:focus-visible .hex {
  stroke: rgba(184, 123, 255, 0.85);
}
.item:hover .logo,
.item:focus-visible .logo {
  stroke: #e9f3ff;
}
.item:hover .glow,
.item:focus-visible .glow {
  opacity: 0.95;
  filter: blur(20px);
}
.item:hover .particles,
.item:focus-visible .particles {
  opacity: 0.75;
  transform: scale(1.12);
}
.item:hover .scan,
.item:focus-visible .scan {
  opacity: 0.35;
  animation: scan 3s linear infinite;
}
.item:hover .ripple,
.item:focus-visible .ripple {
  animation: ripple 0.95s cubic-bezier(0.22, 1, 0.36, 1);
}
.item:hover .tooltip,
.item:focus-visible .tooltip {
  opacity: 1;
  transform: translate(0, -50%);
}
.item:hover .tipLine2,
.item:focus-visible .tipLine2 {
  animation:
    typing 1.1s steps(22, end) forwards 0.18s,
    tipCaret 0.7s steps(2) 5;
  border-right-color: var(--accent-cyan, #5ad7ff);
}

/* ----- Keyframes ----- */
@keyframes float {
  0%,
  100% {
    transform: perspective(900px) rotateY(-8deg) rotateX(2deg) translateY(-5px);
  }
  50% {
    transform: perspective(900px) rotateY(-8deg) rotateX(2deg) translateY(5px);
  }
}
@keyframes breath {
  0%,
  100% {
    opacity: 0.42;
  }
  50% {
    opacity: 0.78;
  }
}
@keyframes drift {
  0%,
  100% {
    transform: translate3d(0, 0, 0);
  }
  33% {
    transform: translate3d(1.5px, -1px, 0);
  }
  66% {
    transform: translate3d(-1px, 1.5px, 0);
  }
}
@keyframes scan {
  0% {
    background-position: 0 0;
  }
  100% {
    background-position: 0 24px;
  }
}
@keyframes flicker {
  0%,
  92%,
  100% {
    opacity: 1;
  }
  93% {
    opacity: 0.86;
  }
  94% {
    opacity: 1;
  }
  95.5% {
    opacity: 0.92;
  }
  96% {
    opacity: 1;
  }
}
@keyframes ripple {
  0% {
    opacity: 0.55;
    transform: translate(-50%, -50%) scale(1);
    border-color: rgba(168, 200, 255, 0.7);
  }
  100% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(14);
    border-color: rgba(184, 123, 255, 0);
  }
}
@keyframes typing {
  to {
    width: 100%;
  }
}
@keyframes tipCaret {
  50% {
    border-right-color: transparent;
  }
}

/* ----- Responsive ----- */
@media (max-width: 1023px) {
  .stack {
    width: 13%;
    right: 3.5%;
    top: 20%;
    transform: translate3d(
      calc(var(--mx) * -3px),
      calc(var(--my) * -3px),
      0
    );
  }
  .tooltip {
    display: none;
  }
}
@media (max-width: 760px) {
  .stack {
    width: 16%;
    right: 3%;
    top: 18%;
    gap: 10%;
    transform: none;
  }
  .item {
    animation: float 7s ease-in-out infinite;
  }
  .scan,
  .ripple {
    display: none;
  }
  .particles {
    opacity: 0.3;
  }
}
@media (max-width: 480px) {
  .stack {
    width: 64px;
    right: 10px;
    top: 14%;
    gap: 14px;
  }
}

/* ----- Reduced motion ----- */
@media (prefers-reduced-motion: reduce) {
  .stack {
    transform: none !important;
    transition: none;
  }
  .item,
  .item:nth-child(2),
  .glow,
  .particles {
    animation: none !important;
  }
  .item:hover .scan,
  .item:focus-visible .scan {
    animation: none;
  }
  .item:hover .ripple,
  .item:focus-visible .ripple {
    animation: none;
  }
  .item:hover .tipLine2,
  .item:focus-visible .tipLine2 {
    width: 100%;
    animation: none;
    border-right-color: transparent;
  }
}

}
.topbar .live {
  display: inline-block;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--success, #4ade80);
  box-shadow: 0 0 8px rgba(74, 222, 128, 0.8);
  animation: livePulse 2.4s ease-in-out infinite;
  margin-right: 7px;
  vertical-align: 1px;
}
.clock {
  font-variant-numeric: tabular-nums;
  color: var(--fg-3, #8a90ad);
}
.clock span {
  color: var(--fg-4, #5a6082);
  margin-left: 4px;
}

/* ---------- Panels ---------- */
.panel {
  position: relative;
  width: 100%;
  min-height: 100svh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80px 20px 60px;
  isolation: isolate;
}

/* ---------- Panel 1 — Identity ---------- */
.identity {
  flex-direction: column;
  gap: 18px;
  text-align: center;
}
.avatar {

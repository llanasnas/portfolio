}
.macroHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--fg-3);
  margin-bottom: 1.5rem;
}
.macroHeader span:first-child {
  color: var(--success);
}
.macroRow {
  display: grid;
  grid-template-columns: 92px 1fr 70px;
  align-items: center;
  gap: 0.9rem;
  margin: 0.85rem 0;
  font-family: var(--font-mono);
  font-size: 12px;
}
.macroRow b {

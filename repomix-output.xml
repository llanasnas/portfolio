/* ============================================================
   GROUPIO STORY — immersive cinematic page
   ============================================================ */

.root {
  position: relative;
  background: #04050a;
  color: var(--fg-1);
  overflow: hidden;
  isolation: isolate;
}

/* Ambient global mesh */
.root::before {
  content: "";
  position: fixed;
  inset: 0;
  background:
    radial-gradient(
      60% 50% at 20% 10%,
      rgba(106, 166, 255, 0.16) 0%,
      transparent 70%
    ),
    radial-gradient(
      50% 50% at 100% 0%,
      rgba(184, 123, 255, 0.14) 0%,
      transparent 70%
    ),
    radial-gradient(
      80% 60% at 50% 100%,
      rgba(90, 215, 255, 0.07) 0%,
      transparent 75%
    );
  pointer-events: none;
  z-index: 0;
}

/* Scan grid */
.grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(106, 166, 255, 0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(106, 166, 255, 0.06) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(
    ellipse 80% 70% at 50% 50%,
    #000 30%,
    transparent 80%
  );
  pointer-events: none;
  z-index: 1;
}

/* Particles (CSS only) */
.particles {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 1;
  overflow: hidden;
}
.particles span {
  position: absolute;
  display: block;
  width: 2px;
  height: 2px;
  border-radius: 50%;
  background: var(--accent-cyan);
  box-shadow:
    0 0 8px var(--accent-cyan),
    0 0 14px rgba(90, 215, 255, 0.6);
  animation: float linear infinite;
  opacity: 0.7;
}
.particles span:nth-child(odd) {
  background: var(--accent-violet);
  box-shadow:
    0 0 10px var(--accent-violet),
    0 0 18px rgba(184, 123, 255, 0.55);
}
@keyframes float {
  0% {
    transform: translate3d(0, 100vh, 0) scale(0.6);
    opacity: 0;
  }
  20% {
    opacity: 0.9;
  }
  100% {
    transform: translate3d(40px, -10vh, 0) scale(1);
    opacity: 0;
  }
}

/* Light beams */
.beams {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}
.beam {
  position: absolute;
  top: -20%;
  width: 2px;
  height: 140%;
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(106, 166, 255, 0.5) 50%,
    transparent 100%
  );
  filter: blur(1px);
  animation: beamSweep 8s ease-in-out infinite;
}
.beam:nth-child(1) {
  left: 12%;
  animation-delay: 0s;
}
.beam:nth-child(2) {
  left: 38%;
  animation-delay: 1.6s;
  background: linear-gradient(
    180deg,
    transparent,
    rgba(184, 123, 255, 0.45),
    transparent
  );
}
.beam:nth-child(3) {
  left: 68%;
  animation-delay: 3.2s;
}
.beam:nth-child(4) {
  left: 88%;
  animation-delay: 4.8s;
  background: linear-gradient(
    180deg,
    transparent,
    rgba(90, 215, 255, 0.45),
    transparent
  );
}
@keyframes beamSweep {
  0%,
  100% {
    opacity: 0;
    transform: translateY(-20px) scaleY(0.6);
  }
  50% {
    opacity: 1;
    transform: translateY(20px) scaleY(1);
  }
}

